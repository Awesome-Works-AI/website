---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "~/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="final-cta" class="relative overflow-hidden bg-white py-28">
  {/* Grid background */}
  <div aria-hidden="true" class="bg-grid pointer-events-none absolute inset-0 opacity-40"></div>

  {/* Sophisticated solid shapes — final visual flourish */}
  <div aria-hidden="true" class="shape-quarter-tl pointer-events-none absolute top-0 left-0 hidden h-60 w-60 bg-green-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-quarter-br pointer-events-none absolute bottom-0 right-0 hidden h-60 w-60 bg-orange-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-arc pointer-events-none absolute -top-2 right-1/4 hidden h-20 w-40 bg-blue-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute left-1/4 top-1/3 hidden h-14 w-16 bg-orange-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute right-12 bottom-1/3 hidden h-12 w-12 bg-green-500/28 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-down pointer-events-none absolute left-12 top-1/2 hidden h-10 w-10 bg-blue-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-trapezoid pointer-events-none absolute right-1/3 bottom-12 hidden h-12 w-28 bg-green-400/20 md:block"></div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <h2 class="text-balance text-4xl font-bold tracking-tight text-ink-900 md:text-6xl">
      {t("final.heading")}
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-balance text-lg text-ink-700 md:text-xl">
      {t("final.subhead")}
    </p>
    <div class="mt-10 flex flex-col items-center gap-4">
      <a
        href="https://calendly.com/hello-awesomeworks/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-full bg-orange-600 px-9 py-4 text-lg font-semibold text-white shadow-sm hover:bg-orange-700 transition"
      >
        {t("final.cta")} →
      </a>
      <a
        href={getLocalizedPath("/poc", lang)}
        class="group inline-flex items-center gap-1.5 text-sm font-semibold text-ink-600 transition hover:text-blue-700"
      >
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        {t("final.cta_secondary")}
        <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
      </a>
    </div>
  </div>
</section>
