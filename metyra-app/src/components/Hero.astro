---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "~/i18n/utils";
import Kicker from "~/components/Kicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-white">
  {/* Dot grid texture */}

  {/* Sophisticated solid shapes — weighted toward RIGHT side (content lives left) */}
  <div aria-hidden="true" class="shape-quarter-tr pointer-events-none absolute -top-10 right-0 hidden h-64 w-64 bg-green-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-half-pill-l pointer-events-none absolute top-1/3 -right-6 hidden h-14 w-36 bg-orange-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute right-20 bottom-1/4 hidden h-20 w-22 bg-blue-300/30 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute right-1/4 top-1/2 hidden h-12 w-12 bg-green-500/30 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-up pointer-events-none absolute bottom-16 right-1/3 hidden h-12 w-12 bg-orange-400/30 md:block"></div>
  <div aria-hidden="true" class="shape-trapezoid pointer-events-none absolute -bottom-8 right-12 hidden h-20 w-44 bg-green-400/20 md:block"></div>
  <div aria-hidden="true" class="shape-arc pointer-events-none absolute top-24 right-1/2 hidden h-12 w-24 bg-blue-400/22 md:block"></div>

  {/* One subtle anchor on the left edge (just enough so content doesn't feel
      totally separated from the background composition) */}
  <div aria-hidden="true" class="shape-quarter-bl pointer-events-none absolute bottom-0 left-0 hidden h-40 w-40 bg-orange-300/18 md:block"></div>

  <div class="relative mx-auto max-w-7xl px-6 pb-24 pt-32 md:pb-40 md:pt-44">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-12">
      <div class="text-center md:col-span-7 md:text-left">
        <Kicker text={t("hero.eyebrow")} tone="blue" status accent="green" />

        <h1 class="mt-7 text-balance text-5xl font-bold leading-[1.05] tracking-tight text-ink-900 md:text-7xl md:leading-[1.0]">
          {t("hero.h1")}
        </h1>

        <p class="mx-auto mt-7 max-w-xl text-balance text-lg text-ink-600 md:mx-0 md:text-xl">
          {t("hero.subhead")}
        </p>

        <div class="mt-10 flex flex-col items-center md:items-start">
          <div class="flex flex-wrap items-center justify-center gap-3 md:justify-start">
            <a
              href="#final-cta"
              class="rounded-full bg-orange-600 px-7 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-orange-700 transition"
            >
              {t("hero.cta_primary")} →
            </a>
            <a
              href={getLocalizedPath("/poc", lang)}
              class="group inline-flex items-center gap-2 rounded-full border-2 border-ink-200 bg-white px-6 py-3 text-base font-semibold text-ink-800 shadow-sm transition hover:border-blue-400 hover:text-blue-700"
            >
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
              </span>
              {t("hero.cta_demo")}
              <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
            </a>
          </div>
          <p class="mt-3 text-xs text-ink-500">{t("hero.cta_subscript")}</p>
        </div>
      </div>

      {/* Right column — intentionally empty on desktop so the section's
          right-weighted shape composition reads as the visual anchor */}
      <div class="hidden md:col-span-5 md:block"></div>
    </div>
  </div>
</section>
