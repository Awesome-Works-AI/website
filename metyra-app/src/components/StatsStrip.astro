---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { key: "s1", color: "text-green-600" },
  { key: "s2", color: "text-blue-700" },
  { key: "s3", color: "text-orange-600" },
] as const;
---

<section class="relative overflow-hidden bg-white py-20">
  {/* Concentric rings background motif (CSS gradient, not blur) */}
  <div aria-hidden="true" class="bg-rings pointer-events-none absolute inset-0 opacity-90"></div>

  {/* Sophisticated solid shapes */}
  <div aria-hidden="true" class="shape-half-pill-r pointer-events-none absolute -left-8 top-12 hidden h-12 w-40 bg-green-400/20 md:block"></div>
  <div aria-hidden="true" class="shape-half-pill-l pointer-events-none absolute -right-8 bottom-12 hidden h-12 w-40 bg-orange-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute top-1/2 left-1/4 hidden h-10 w-12 -translate-y-1/2 bg-blue-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute top-1/2 right-1/4 hidden h-10 w-12 -translate-y-1/2 bg-orange-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute top-8 right-1/3 hidden h-8 w-8 bg-green-500/25 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-down pointer-events-none absolute bottom-8 left-1/3 hidden h-8 w-8 bg-orange-500/25 md:block"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <h2 class="mx-auto max-w-2xl text-center text-2xl font-bold tracking-tight text-ink-900 md:text-3xl">
      {t("stats.heading")}
    </h2>
    <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-3">
      {
        stats.map((s) => (
          <div class="text-center">
            <div class={`text-5xl font-bold tracking-tight ${s.color} md:text-6xl`}>
              {t(`stats.${s.key}.value` as any)}
            </div>
            <div class="mt-3 text-sm text-ink-600">{t(`stats.${s.key}.label` as any)}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
