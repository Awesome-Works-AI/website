---
import { PALETTE, AXIS_COLOR, GRID_COLOR, niceTicks, fmt } from "./chart-utils";

interface Props {
  data: {
    title?: string;
    unit?: string;
    x_label?: string;
    series?: string[];
    data?: Array<Record<string, string | number>>;
  } | null;
}
const { data } = Astro.props;
const rows = data?.data ?? [];
const series = data?.series ?? [];
if (rows.length === 0 || series.length === 0) return null;

const W = 720;
const H = 300;
const PADDING = { top: 16, right: 16, bottom: 44, left: 56 };
const innerW = W - PADDING.left - PADDING.right;
const innerH = H - PADDING.top - PADDING.bottom;

let minV = Infinity;
let maxV = -Infinity;
for (const r of rows) for (const s of series) {
  const v = Number(r[s] ?? 0);
  if (!isNaN(v)) {
    if (v < minV) minV = v;
    if (v > maxV) maxV = v;
  }
}
if (minV === Infinity) { minV = 0; maxV = 1; }
const ticks = niceTicks(minV, maxV, 5);
const yMin = ticks[0];
const yMax = ticks[ticks.length - 1];

const step = innerW / Math.max(rows.length - 1, 1);
const xPos = (i: number) => PADDING.left + i * step;
const yPos = (v: number) =>
  PADDING.top + innerH - ((v - yMin) / (yMax - yMin || 1)) * innerH;

// Show every Nth x-tick if many
const xTickEvery = rows.length > 8 ? Math.ceil(rows.length / 8) : 1;
---

<div class="rounded-2xl border border-ink-200 bg-white p-5 shadow-sm">
  {data?.title && <div class="mb-3 text-sm font-semibold text-ink-900">{data.title}</div>}
  <div class="overflow-x-auto">
    <svg viewBox={`0 0 ${W} ${H}`} class="h-72 w-full min-w-[640px]" role="img" aria-label={data?.title}>
      {ticks.map((t) => (
        <g>
          <line x1={PADDING.left} x2={W - PADDING.right} y1={yPos(t)} y2={yPos(t)} stroke={GRID_COLOR} stroke-dasharray="3 3" />
          <text x={PADDING.left - 8} y={yPos(t) + 4} text-anchor="end" font-size="11" fill={AXIS_COLOR}>
            {fmt(t)}
          </text>
        </g>
      ))}
      {rows.map((r, i) => (
        i % xTickEvery === 0 && (
          <text x={xPos(i)} y={H - PADDING.bottom + 16} text-anchor="middle" font-size="10" fill={AXIS_COLOR}>
            {r.period as string}
          </text>
        )
      ))}
      {series.map((s, si) => {
        const color = PALETTE[si % PALETTE.length];
        const points = rows.map((r, i) => `${xPos(i)},${yPos(Number(r[s] ?? 0))}`).join(" ");
        return (
          <g>
            <polyline points={points} fill="none" stroke={color} stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round" />
            {rows.map((r, i) => {
              const v = Number(r[s] ?? 0);
              return (
                <circle cx={xPos(i)} cy={yPos(v)} r="2.6" fill={color}>
                  <title>{r.period}: {s} = {fmt(v)}{data?.unit ?? ""}</title>
                </circle>
              );
            })}
          </g>
        );
      })}
    </svg>
  </div>
  <div class="mt-3 flex flex-wrap gap-3 text-xs text-ink-600">
    {series.map((s, i) => (
      <span class="inline-flex items-center gap-1.5">
        <span class="h-0.5 w-4" style={`background:${PALETTE[i % PALETTE.length]}`}></span>
        <span class="font-medium">{s}</span>
      </span>
    ))}
  </div>
</div>
