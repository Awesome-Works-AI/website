---
import Sparkline from "./Sparkline.astro";

interface Props {
  data: {
    label?: string;
    value?: string;
    unit?: string;
    delta?: { value?: string; direction?: "up" | "down" | "neutral"; label?: string };
    spark?: number[];
    status?: "green" | "amber" | "red" | "neutral";
    caption?: string;
  } | null;
}
const { data } = Astro.props;
if (!data) return null;

const status = data.status ?? "neutral";
const dir = data.delta?.direction ?? "neutral";

const statusBorder: Record<string, string> = {
  green: "border-green-200",
  amber: "border-amber-200",
  red: "border-red-200",
  neutral: "border-ink-200",
};
const statusDot: Record<string, string> = {
  green: "bg-green-500",
  amber: "bg-amber-500",
  red: "bg-red-500",
  neutral: "bg-ink-300",
};
const deltaColor: Record<string, string> = {
  up: "text-green-700 bg-green-50",
  down: "text-red-700 bg-red-50",
  neutral: "text-ink-600 bg-ink-100",
};
const sparkColor =
  status === "green"
    ? "#059669"
    : status === "red"
      ? "#DC2626"
      : status === "amber"
        ? "#D97706"
        : "#16467D";

const arrow = dir === "up" ? "↑" : dir === "down" ? "↓" : "−";
---

<div class={`rounded-2xl border ${statusBorder[status]} bg-white p-4 shadow-sm`}>
  <div class="flex items-start justify-between gap-2">
    <div class="text-[11px] font-semibold uppercase tracking-wider text-ink-500">{data.label}</div>
    <span class={`h-2 w-2 rounded-full ${statusDot[status]}`} title={status}></span>
  </div>
  <div class="mt-2 flex items-baseline gap-1.5">
    <span class="text-2xl font-bold tracking-tight text-ink-900">{data.value}</span>
    {data.unit && <span class="text-xs font-medium text-ink-500">{data.unit}</span>}
  </div>
  <div class="mt-3 flex items-center justify-between gap-2">
    {data.delta?.value && (
      <span class={`inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-semibold ${deltaColor[dir]}`}>
        <span aria-hidden="true">{arrow}</span>
        {data.delta.value}
        {data.delta.label && <span class="ml-0.5 font-normal opacity-80">{data.delta.label}</span>}
      </span>
    )}
    {data.spark && data.spark.length >= 2 && (
      <Sparkline values={data.spark} color={sparkColor} width={100} height={32} />
    )}
  </div>
  {data.caption && <div class="mt-2 text-[11px] text-ink-500">{data.caption}</div>}
</div>
