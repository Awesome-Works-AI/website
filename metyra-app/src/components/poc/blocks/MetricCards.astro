---
interface Card {
  label: string;
  value: string;
  unit?: string;
  tone?: "orange" | "blue" | "green" | "neutral";
  caption?: string;
}
interface Props {
  data: { cards?: Card[] } | null;
}
const { data } = Astro.props;
const cards = data?.cards ?? [];

const toneClass: Record<string, string> = {
  orange: "bg-orange-500",
  blue: "bg-blue-600",
  green: "bg-green-600",
  neutral: "bg-ink-400",
};
---

{cards.length > 0 && (
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {cards.map((c) => (
      <div class="relative overflow-hidden rounded-2xl border border-ink-200 bg-white p-5 shadow-sm">
        <div class={`absolute inset-x-0 top-0 h-1 ${toneClass[c.tone ?? "neutral"]}`}></div>
        <div class="text-[10px] font-semibold uppercase tracking-wider text-ink-500">{c.label}</div>
        <div class="mt-2 flex items-baseline gap-1.5">
          <span class="text-3xl font-bold tracking-tight text-ink-900">{c.value}</span>
          {c.unit && <span class="text-sm font-medium text-ink-500">{c.unit}</span>}
        </div>
        {c.caption && <div class="mt-2 text-xs text-ink-600">{c.caption}</div>}
      </div>
    ))}
  </div>
)}
