---
interface Driver {
  name: string;
  direction?: "up" | "down" | "neutral";
  impact?: string;
  description?: string;
}
interface Props {
  data: { title?: string; drivers?: Driver[] } | null;
}
const { data } = Astro.props;
const drivers = data?.drivers ?? [];
if (drivers.length === 0) return null;

const DIR_BADGE: Record<string, string> = {
  up: "bg-green-50 text-green-700",
  down: "bg-red-50 text-red-700",
  neutral: "bg-ink-100 text-ink-600",
};
const arrow = (d?: string) => (d === "up" ? "↑" : d === "down" ? "↓" : "−");
---

<div class="rounded-2xl border border-ink-200 bg-white p-5 shadow-sm">
  {data?.title && <div class="mb-3 text-sm font-semibold text-ink-900">{data.title}</div>}
  <div class="grid gap-3 sm:grid-cols-2">
    {drivers.map((d) => (
      <div class="rounded-xl border border-ink-200 bg-ink-50/40 p-3">
        <div class="flex items-center gap-2">
          <span class={`grid h-7 w-7 place-items-center rounded-md text-sm font-bold ${DIR_BADGE[d.direction ?? "neutral"]}`}>
            {arrow(d.direction)}
          </span>
          <span class="font-semibold text-ink-900">{d.name}</span>
        </div>
        {d.impact && <div class="mt-2 text-sm font-medium tabular-nums text-ink-800">{d.impact}</div>}
        {d.description && <div class="mt-1 text-xs text-ink-600">{d.description}</div>}
      </div>
    ))}
  </div>
</div>
