---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items: UiKey[] = [
  "enemy.item1",
  "enemy.item2",
  "enemy.item3",
  "enemy.item4",
  "enemy.item5",
  "enemy.item6",
  "enemy.item7",
  "enemy.item8",
];
---

<section class="relative overflow-hidden bg-white py-24">
  {/* Hatch background pattern */}
  <div aria-hidden="true" class="bg-hatch pointer-events-none absolute inset-0 opacity-80"></div>

  {/* Sophisticated solid shapes */}
  <div aria-hidden="true" class="shape-trapezoid pointer-events-none absolute -top-10 right-1/4 hidden h-28 w-56 bg-orange-300/22 md:block"></div>
  <div aria-hidden="true" class="shape-l pointer-events-none absolute bottom-12 -left-2 hidden h-32 w-32 bg-green-400/20 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute top-1/3 right-12 hidden h-14 w-16 bg-blue-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute bottom-32 right-1/3 hidden h-10 w-10 bg-orange-500/30 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-up pointer-events-none absolute top-24 left-1/3 hidden h-10 w-10 bg-green-500/25 md:block"></div>

  <div class="relative mx-auto max-w-5xl px-6 text-center">
    <h2 class="text-balance text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">
      {t("enemy.heading")}
    </h2>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-ink-600">{t("enemy.subhead")}</p>

    <ul class="mx-auto mt-14 grid max-w-3xl grid-cols-1 gap-x-10 gap-y-5 text-left sm:grid-cols-2">
      {
        items.map((key) => (
          <li class="flex items-start gap-3">
            <svg
              class="mt-1 h-5 w-5 flex-none text-orange-500"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
            <span class="text-base leading-relaxed text-ink-700">{t(key)}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
