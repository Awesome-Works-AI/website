---
/**
 * Kicker — Metyra's custom eyebrow/tag.
 *
 * Replaces the AI-default `rounded-full px-3 py-1 text-xs uppercase tracking-wider`
 * pill that screams "SaaS template". Design language:
 *
 *   - sharp rectangle (no rounded corners — geometric, not soft)
 *   - mono uppercase with tighter tracking (editorial, not screaming)
 *   - 1px solid border in brand tone
 *   - optional offset accent (3px shadow behind in green/orange) → "stamped" effect
 *   - optional pulse dot (square, not circle — matches the rest of the language)
 *
 * Variants
 *   default  → section eyebrows (Hero, Roadmap, PilotCta)
 *   compact  → in-content tags (Roadmap day pills, ProductSplit module tags)
 *
 * Tones: blue (primary), green, orange.
 */

interface Props {
  text: string;
  variant?: "default" | "compact";
  tone?: "blue" | "green" | "orange";
  /** Show a 3px offset accent behind the tag — "stamped" look. */
  accent?: "green" | "orange" | "none";
  /** Show a pulsing status dot on the left (e.g. "live") */
  status?: boolean;
  /** Extra utility classes for outer wrapper. */
  class?: string;
}

const {
  text,
  variant = "default",
  tone = "blue",
  accent = "none",
  status = false,
  class: extraClass = "",
} = Astro.props;

const toneRing = {
  blue:   "border-blue-700 text-blue-700",
  green:  "border-green-700 text-green-700",
  orange: "border-orange-700 text-orange-700",
}[tone];

const dotBg = {
  blue:   "bg-green-500",
  green:  "bg-green-500",
  orange: "bg-orange-500",
}[tone];

const accentBg = {
  green:  "bg-green-500",
  orange: "bg-orange-500",
  none:   "",
}[accent];

const isCompact = variant === "compact";

/* Sizing per variant — keep both compact and default visually paired with section weight. */
const sizing = isCompact
  ? "px-2 py-[3px] text-[10px] tracking-[0.12em]"
  : "px-3 py-[5px] text-[11px] tracking-[0.14em]";
---

<span class={`kicker relative inline-flex items-center ${extraClass}`}>
  {accent !== "none" && (
    <span
      aria-hidden="true"
      class={`kicker-accent absolute inset-0 ${accentBg}`}
    ></span>
  )}
  <span
    class={`relative inline-flex items-center gap-2 border bg-white ${toneRing} ${sizing} font-mono uppercase`}
  >
    {status && (
      <span class={`inline-block h-1.5 w-1.5 ${dotBg} animate-pulse`} aria-hidden="true"></span>
    )}
    <span>{text}</span>
  </span>
</span>

<style>
  /* 3px offset shadow gives the "stamp / ticket stub" effect.
     Sits behind the foreground rectangle via z-index from `.relative`. */
  .kicker-accent {
    transform: translate(3px, 3px);
  }
</style>
