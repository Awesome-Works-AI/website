---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<a
  href="#pilot"
  class="block border-b border-blue-100 bg-blue-50 py-2.5 text-center text-sm transition hover:bg-blue-100/60"
>
  <span class="mr-2 inline-flex items-center rounded-full bg-blue-600/10 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wider text-blue-700">
    {t("banner.founding.eyebrow")}
  </span>
  <span class="text-ink-800">{t("banner.founding.text")}</span>
  <span class="ml-2 font-semibold text-orange-600">{t("banner.founding.link")} →</span>
</a>
