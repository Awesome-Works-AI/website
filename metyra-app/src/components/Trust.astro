---
interface Logo {
  name: string;
  src: string;
  /* Height tuned per-logo so visual weight feels equal across very different aspect ratios. */
  h: string;
  /* Optional extra class — e.g. darken pale logos so they read on white. */
  extra?: string;
}

const logos: Logo[] = [
  { name: "Deloitte",       src: "/logos/deloitte.svg",      h: "h-6 md:h-7"  },
  { name: "PwC",            src: "/logos/pwc.png",           h: "h-10 md:h-12" },
  { name: "Odoo",           src: "/logos/odoo.svg",          h: "h-11 md:h-13" },
  { name: "Gemius",         src: "/logos/gemius.svg",        h: "h-5 md:h-6"  },
  { name: "Gorąco Polecam", src: "/logos/goracopolecam.svg", h: "h-10 md:h-12" },
  { name: "Thirty3",        src: "/logos/thirty3.webp",      h: "h-9 md:h-11", extra: "logo-darken" },
  { name: "SDA",            src: "/logos/sda.svg",           h: "h-8 md:h-9"  },
];

/* Render the list twice for a seamless infinite scroll. */
const marquee = [...logos, ...logos];
---

<section class="relative overflow-hidden bg-white py-20">
  {/* Light decorative shapes */}
  <div aria-hidden="true" class="shape-half-pill-r pointer-events-none absolute -left-10 top-1/3 hidden h-10 w-32 bg-green-400/12 md:block"></div>
  <div aria-hidden="true" class="shape-half-pill-l pointer-events-none absolute -right-10 bottom-1/4 hidden h-10 w-32 bg-orange-400/15 md:block"></div>

  <div class="relative marquee-mask">
    <div class="marquee-track">
      {
        marquee.map((logo, i) => (
          <div class="marquee-item">
            <img
              src={logo.src}
              alt={i < logos.length ? logo.name : ""}
              aria-hidden={i >= logos.length ? "true" : undefined}
              class={`${logo.h} w-auto select-none opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0 ${logo.extra ?? ""}`}
              loading="lazy"
              decoding="async"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Soft side fades */
  .marquee-mask {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .marquee-track {
    display: flex;
    width: max-content;
    align-items: center;
    animation: marquee 38s linear infinite;
  }

  /* Per-item margin-right (not flex gap) so EVERY item — including the last
     of each copy — has a trailing gap. That makes translateX(-50%) land
     perfectly on the seam, no visible "longer gap" at the loop. */
  .marquee-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    min-width: 8rem;
    margin-right: 4rem;
  }

  /* Pause for readers */
  .marquee-track:hover {
    animation-play-state: paused;
  }

  /* Darken pale logos (e.g. Thirty3 light gray on white) */
  .logo-darken {
    filter: brightness(0.45) contrast(1.15);
  }
  .logo-darken:hover {
    filter: none;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    /* Track holds 2 copies of the list with uniform per-item trailing margin.
       Sliding by exactly 50% of the track width = one full copy width,
       which is identical to the leading edge of copy 2 — seamless. */
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
