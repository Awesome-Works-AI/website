---
import LogoMarquee, { type MarqueeLogo } from "~/components/LogoMarquee.astro";

/* Prefix `/logos/...` with Astro's configured base path so assets resolve under
   `awesomeworks.ai/metyra/` in production instead of 404ing at the site root. */
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const logos: MarqueeLogo[] = [
  { name: "Deloitte",       src: `${base}/logos/deloitte.svg`,      h: "h-6 md:h-7"  },
  { name: "PwC",            src: `${base}/logos/pwc.png`,           h: "h-10 md:h-12" },
  { name: "Odoo",           src: `${base}/logos/odoo.svg`,          h: "h-11 md:h-13" },
  { name: "Gemius",         src: `${base}/logos/gemius.svg`,        h: "h-5 md:h-6"  },
  { name: "Gorąco Polecam", src: `${base}/logos/goracopolecam.svg`, h: "h-10 md:h-12" },
  { name: "Thirty3",        src: `${base}/logos/thirty3.webp`,      h: "h-9 md:h-11", extra: "logo-darken" },
  { name: "SDA",            src: `${base}/logos/sda.svg`,           h: "h-8 md:h-9"  },
];
---

<section class="relative overflow-hidden bg-white py-20">
  {/* Light decorative shapes */}
  <div aria-hidden="true" class="shape-half-pill-r pointer-events-none absolute -left-10 top-1/3 hidden h-10 w-32 bg-green-400/12 md:block"></div>
  <div aria-hidden="true" class="shape-half-pill-l pointer-events-none absolute -right-10 bottom-1/4 hidden h-10 w-32 bg-orange-400/15 md:block"></div>

  <LogoMarquee logos={logos} />
</section>
