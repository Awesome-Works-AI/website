---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import Kicker from "~/components/Kicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="pilot" class="relative overflow-hidden bg-white py-32">
  {/* Dot grid base */}

  {/* Sophisticated solid shapes — strong composition, no blur */}
  <div aria-hidden="true" class="shape-quarter-br pointer-events-none absolute bottom-0 right-0 hidden h-56 w-56 bg-orange-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-quarter-tl pointer-events-none absolute top-0 left-0 hidden h-56 w-56 bg-green-400/20 md:block"></div>
  <div aria-hidden="true" class="shape-arc pointer-events-none absolute -top-4 left-1/4 hidden h-16 w-32 bg-blue-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute right-12 top-1/3 hidden h-14 w-16 bg-orange-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute left-12 bottom-1/3 hidden h-12 w-12 bg-green-500/28 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-up pointer-events-none absolute right-1/3 top-16 hidden h-10 w-10 bg-blue-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-trapezoid pointer-events-none absolute left-1/3 bottom-16 hidden h-14 w-32 bg-green-400/20 md:block"></div>
  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <Kicker text={t("pilot.eyebrow")} tone="blue" status accent="orange" />
    <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">
      {t("pilot.heading")}
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-700">{t("pilot.body")}</p>
    <a
      href="https://calendly.com/hello-awesomeworks/30min"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-10 inline-block rounded-full bg-orange-600 px-7 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-orange-700 transition"
    >
      {t("pilot.cta")} →
    </a>
  </div>
</section>
