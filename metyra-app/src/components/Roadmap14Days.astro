---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";
import Kicker from "~/components/Kicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Phase {
  day: UiKey;
  title: UiKey;
  body: UiKey;
}

const phases: Phase[] = [
  { day: "roadmap.p1.day", title: "roadmap.p1.title", body: "roadmap.p1.body" },
  { day: "roadmap.p2.day", title: "roadmap.p2.title", body: "roadmap.p2.body" },
  { day: "roadmap.p3.day", title: "roadmap.p3.title", body: "roadmap.p3.body" },
  { day: "roadmap.p4.day", title: "roadmap.p4.title", body: "roadmap.p4.body" },
];
---

<section class="relative overflow-hidden bg-white py-28">
  {/* Dot grid base */}

  {/* Sophisticated solid shapes anchored at journey endpoints */}
  <div aria-hidden="true" class="shape-half-pill-r pointer-events-none absolute -left-12 top-1/3 hidden h-16 w-44 bg-green-400/20 md:block"></div>
  <div aria-hidden="true" class="shape-half-pill-l pointer-events-none absolute -right-12 bottom-1/4 hidden h-16 w-44 bg-orange-400/22 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute right-16 top-32 hidden h-10 w-10 bg-blue-400/30 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute left-1/4 bottom-32 hidden h-12 w-14 bg-orange-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-down pointer-events-none absolute right-1/3 bottom-20 hidden h-10 w-10 bg-green-500/25 md:block"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <Kicker text={t("roadmap.eyebrow")} tone="blue" status accent="green" />
      <h2 class="mt-5 text-balance text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">
        {t("roadmap.heading")}
      </h2>

      {/* Creative composition: 3 strikethrough tags replace the kicker sentence */}
      <div class="mt-7 flex flex-wrap items-center justify-center gap-2">
        {(["roadmap.no1", "roadmap.no2", "roadmap.no3"] as const).map((key) => (
          <span class="inline-flex items-center gap-1.5 border border-orange-700 bg-white px-2.5 py-[5px] font-mono text-[11px] uppercase tracking-[0.12em] text-orange-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
            <span class="line-through decoration-orange-600 decoration-2">{t(key)}</span>
          </span>
        ))}
      </div>
    </div>

    <div class="relative mt-16">
      <div
        aria-hidden="true"
        class="absolute hidden md:block h-px left-[12.5%] right-[12.5%] top-[26px] bg-gradient-to-r from-blue-200 via-blue-500 to-blue-200"
      ></div>
      <div
        aria-hidden="true"
        class="absolute md:hidden top-4 bottom-4 left-[28px] w-px bg-gradient-to-b from-blue-200 via-blue-500 to-blue-200"
      ></div>

      <div class="grid grid-cols-1 gap-y-16 md:grid-cols-4 md:gap-x-4 md:gap-y-0">
        {
          phases.map((phase, idx) => (
            <div class="relative">
              <div class="relative hidden md:flex justify-center pt-4">
                <div class="h-5 w-5 rounded-full bg-blue-700 ring-[6px] ring-white shadow-md" />
                {idx === 0 && (
                  <div aria-hidden="true" class="pointer-events-none absolute top-4 h-5 w-5 animate-ping rounded-full bg-green-400/60" />
                )}
              </div>

              <div class="md:hidden flex items-start gap-6 relative">
                <div class="relative z-10 mt-1 flex-none">
                  <div class="h-4 w-4 rounded-full bg-blue-700 ring-4 ring-white shadow-sm" />
                </div>
                <div class="flex-1">
                  <Kicker text={t(phase.day)} variant="compact" tone="blue" />
                  <h3 class="mt-3 text-xl font-bold text-ink-900">{t(phase.title)}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink-600">{t(phase.body)}</p>
                </div>
              </div>

              <div class="hidden md:block relative mt-6 text-center">
                <Kicker text={t(phase.day)} variant="compact" tone="blue" />
                <h3 class="mt-4 text-xl font-bold text-ink-900">{t(phase.title)}</h3>
                <p class="mx-auto mt-3 max-w-[15rem] text-sm leading-relaxed text-ink-600">{t(phase.body)}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-20 text-center">
      <p class="inline-flex items-center gap-2 text-sm text-ink-500">
        <span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span>
        <span class="font-semibold text-ink-700">{t("roadmap.footnote.day")}</span>
        <span>{t("roadmap.footnote.text")}</span>
      </p>
    </div>
  </div>
</section>
