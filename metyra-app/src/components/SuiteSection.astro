---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import ProductSplit from "./ProductSplit.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="product" class="relative overflow-hidden bg-white py-24">
  {/* Dot pattern overlay */}

  {/* Sophisticated solid shapes anchored at corners + between splits */}
  <div aria-hidden="true" class="shape-quarter-tl pointer-events-none absolute top-0 right-0 hidden h-44 w-44 bg-orange-300/20 md:block"></div>
  <div aria-hidden="true" class="shape-quarter-br pointer-events-none absolute bottom-0 left-0 hidden h-44 w-44 bg-green-400/18 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute top-1/4 left-12 hidden h-14 w-16 bg-blue-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute top-1/2 right-12 hidden h-10 w-10 bg-orange-500/25 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-down pointer-events-none absolute bottom-1/3 right-1/4 hidden h-10 w-10 bg-green-500/25 md:block"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-balance text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">
        {t("suite.heading")}
      </h2>
      <p class="mt-5 text-lg text-ink-600">{t("suite.kicker")}</p>
    </div>

    <div class="mt-20 space-y-28">
      <ProductSplit
        tag="product.boardpack.tag"
        title="product.boardpack.title"
        body="product.boardpack.body"
        bullets={["product.boardpack.b1", "product.boardpack.b2", "product.boardpack.b3"]}
        visual="boardpack"
      />
      <ProductSplit
        tag="product.qa.tag"
        title="product.qa.title"
        body="product.qa.body"
        bullets={["product.qa.b1", "product.qa.b2", "product.qa.b3"]}
        reverse
        visual="qa"
      />
      <ProductSplit
        tag="product.ksef.tag"
        title="product.ksef.title"
        body="product.ksef.body"
        bullets={["product.ksef.b1", "product.ksef.b2", "product.ksef.b3"]}
        visual="ksef"
      />
    </div>
  </div>
</section>
