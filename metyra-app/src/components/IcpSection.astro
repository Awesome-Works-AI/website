---
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards: { title: UiKey; body: UiKey; accent: string }[] = [
  { title: "icp.c1.title", body: "icp.c1.body", accent: "bg-green-500" },
  { title: "icp.c2.title", body: "icp.c2.body", accent: "bg-blue-600" },
  { title: "icp.c3.title", body: "icp.c3.body", accent: "bg-orange-500" },
  { title: "icp.c4.title", body: "icp.c4.body", accent: "bg-green-500" },
];
---

<section id="icp" class="relative overflow-hidden bg-white py-28">
  {/* Dot grid base */}

  {/* Sophisticated solid shapes */}
  <div aria-hidden="true" class="shape-quarter-tr pointer-events-none absolute top-0 right-0 hidden h-40 w-40 bg-green-400/18 md:block"></div>
  <div aria-hidden="true" class="shape-quarter-bl pointer-events-none absolute bottom-0 left-0 hidden h-40 w-40 bg-orange-300/22 md:block"></div>
  <div aria-hidden="true" class="shape-hex pointer-events-none absolute top-1/3 left-12 hidden h-12 w-14 bg-blue-400/25 md:block"></div>
  <div aria-hidden="true" class="shape-plus pointer-events-none absolute bottom-24 right-12 hidden h-10 w-10 bg-orange-500/25 md:block"></div>
  <div aria-hidden="true" class="shape-triangle-up pointer-events-none absolute top-1/2 right-1/4 hidden h-9 w-9 bg-green-500/25 md:block"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-balance text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">
        {t("icp.heading")}
      </h2>
      <p class="mt-5 text-lg text-ink-600">{t("icp.kicker")}</p>
    </div>

    {/* No cards: content sits in space with accent markers + dividers on desktop */}
    <div class="mt-16 grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-0 lg:divide-x lg:divide-ink-200/70">
      {
        cards.map((c) => (
          <div class="px-2 lg:px-8 first:lg:pl-0 last:lg:pr-0">
            <div class="flex items-center gap-2">
              <div class={`h-2 w-2 rounded-full ${c.accent}`} />
              <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-blue-700">{t(c.title)}</div>
            </div>
            <div class="mt-3 text-base leading-relaxed text-ink-800">{t(c.body)}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
