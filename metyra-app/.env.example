# Frontend build-time configuration for the Metyra landing.
# Public vars are exposed to the browser (PUBLIC_ prefix is required).
# Copy to `.env` for local dev. In CI/CD set as env vars on the workflow.

# Where the live POC backend lives.
# Local dev: leave empty — Vite dev server proxies /api/poc to localhost:8100.
# Production: https://app.metyra.awesomeworks.ai
PUBLIC_METYRA_API_BASE=
