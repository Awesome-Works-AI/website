---
import { pl } from "../i18n/pl";
const i = pl.pricing;
---

<section id="pricing" class="gradient-mesh py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto mb-10 max-w-2xl text-center animate-on-scroll">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {i.title}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        {i.subtitle}
      </p>
    </div>

    <!-- Per-invoice callout -->
    <div class="mx-auto mb-12 max-w-2xl animate-on-scroll">
      <div class="rounded-2xl border border-primary/20 bg-primary/5 p-6 sm:p-8 text-center">
        <div class="flex items-baseline justify-center gap-2">
          <span class="text-5xl font-bold tracking-tight text-foreground">{i.perInvoice.price}</span>
          <span class="text-xl text-muted-foreground">{i.perInvoice.unit}</span>
        </div>
        <p class="mt-2 text-sm text-muted-foreground">{i.perInvoice.description}</p>
        <div class="mt-6 grid gap-2 sm:grid-cols-2 text-left">
          {i.perInvoice.includes.map((item) => (
            <div class="flex items-start gap-2 text-sm text-foreground/80">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Pricing cards -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        i.plans.map((plan, idx) => (
          <div
            class:list={[
              "animate-on-scroll rounded-2xl p-7 sm:p-8 transition-all duration-200 flex flex-col",
              plan.highlighted
                ? "border-2 border-primary/30 bg-white/[0.05] shadow-xl shadow-blue-500/10 relative"
                : "border border-white/[0.06] bg-white/[0.03]",
            ]}
            style={`transition-delay: ${idx * 100}ms`}
          >
            {/* Popular badge */}
            {plan.highlighted && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="rounded-full bg-gradient-to-r from-blue-600 to-cyan-600 px-4 py-1 text-xs font-semibold text-white shadow-lg shadow-blue-500/25">
                  Rekomendowany
                </span>
              </div>
            )}

            {/* Plan name */}
            <h3 class="text-xl font-semibold text-foreground">{plan.name}</h3>
            <p class="mt-1 text-sm text-muted-foreground">
              {plan.description}
            </p>

            {/* Price */}
            <div class="mt-6 mb-6">
              {plan.period ? (
                <div class="flex items-baseline gap-1">
                  <span class="text-4xl font-bold tracking-tight text-foreground">
                    {plan.price}
                  </span>
                  <span class="text-lg text-muted-foreground">zł</span>
                  <span class="text-muted-foreground">{plan.period}</span>
                </div>
              ) : (
                <div class="text-4xl font-bold tracking-tight text-foreground">
                  {plan.price}
                </div>
              )}
            </div>

            {/* Features */}
            <ul class="mb-8 flex-1 space-y-3">
              {plan.features.map((feature) => {
                const isSeparator = feature.startsWith("Wszystko z planu");
                return isSeparator ? (
                  <li class="flex items-center gap-2 pt-2 border-t border-white/[0.06]">
                    <span class="text-xs font-medium uppercase tracking-wider text-primary/70">{feature}</span>
                  </li>
                ) : (
                  <li class="flex items-start gap-3 text-sm text-foreground/80">
                    <svg
                      class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {feature}
                  </li>
                );
              })}
            </ul>

            {/* CTA */}
            <a
              href="https://calendly.com/hello-awesomeworks/30min"
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "block w-full rounded-xl px-6 py-3 text-center text-sm font-semibold transition-all duration-200",
                plan.highlighted
                  ? "bg-gradient-to-r from-blue-600 to-cyan-600 text-white shadow-lg shadow-blue-500/25 hover:shadow-xl hover:shadow-blue-500/30 hover:brightness-110"
                  : "border border-white/[0.1] bg-white/[0.04] text-foreground hover:bg-white/[0.08]",
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
