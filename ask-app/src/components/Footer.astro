---
import { pl } from "../i18n/pl";
import { withBase } from "../utils/url";
const i = pl.footer;
const year = new Date().getFullYear();

const resolveHref = (href: string) =>
  href.startsWith("/") && !href.startsWith("//") ? withBase(href) : href;
---

<footer class="border-t border-white/[0.06] bg-background py-12 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Footer grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2.5">
          <img
            src={withBase("/logo_transparent.png")}
            alt="AwesomeWorks Ask"
            class="h-8 w-8 rounded-xl"
            width="32"
            height="32"
          />
          <span class="text-base font-bold tracking-tight text-foreground">
            {i.brand}
          </span>
        </div>
        <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
          {i.tagline}
        </p>
      </div>

      <!-- Product links -->
      <div>
        <h4 class="mb-4 text-sm font-semibold text-foreground">
          {i.product.title}
        </h4>
        <ul class="space-y-2.5">
          {
            i.product.links.map((link) => (
              <li>
                <a
                  href={resolveHref(link.href)}
                  class="text-sm text-muted-foreground transition-colors duration-200 hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <h4 class="mb-4 text-sm font-semibold text-foreground">
          {i.company.title}
        </h4>
        <ul class="space-y-2.5">
          {
            i.company.links.map((link) => (
              <li>
                <a
                  href={resolveHref(link.href)}
                  class="text-sm text-muted-foreground transition-colors duration-200 hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal links -->
      <div>
        <h4 class="mb-4 text-sm font-semibold text-foreground">
          {i.legal.title}
        </h4>
        <ul class="space-y-2.5">
          {
            i.legal.links.map((link) => (
              <li>
                <a
                  href={resolveHref(link.href)}
                  class="text-sm text-muted-foreground transition-colors duration-200 hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 border-t border-white/[0.06] pt-6 text-center text-xs text-muted-foreground"
    >
      &copy; {year} {i.copyright}
    </div>
  </div>
</footer>
