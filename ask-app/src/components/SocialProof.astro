---
import { pl } from "../i18n/pl";
const i = pl.socialProof;
---

<section class="border-y border-white/[0.06] bg-white/[0.01] py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <p class="mb-8 text-center text-sm font-semibold uppercase tracking-wider text-muted-foreground">
      {i.label}
    </p>
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
      {
        i.stats.map((stat) => (
          <div class="text-center animate-on-scroll">
            <div class="text-3xl font-bold tracking-tight text-foreground">
              {stat.value}
            </div>
            <div class="mt-1 text-sm text-muted-foreground">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
