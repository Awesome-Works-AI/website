---
import { pl } from "../i18n/pl";
const i = pl.howItWorks;

const stepIcons = [
  "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12", // Upload/Receive
  "M12 2a7 7 0 017 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 01-2 2h-4a2 2 0 01-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 017-7z M9 22h6", // AI Brain
  "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", // Approve checkmark
];
---

<section
  id="how-it-works"
  class="border-y border-white/[0.06] bg-white/[0.01] py-20 sm:py-28"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center animate-on-scroll">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {i.title}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        {i.subtitle}
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid gap-8 md:grid-cols-3 md:gap-12">
      <!-- Connecting line (desktop) -->
      <div
        class="absolute left-0 right-0 top-16 hidden border-t-2 border-dashed border-white/[0.06] md:block"
        style="left: 16.67%; right: 16.67%;"
      >
      </div>

      {
        i.steps.map((step, idx) => (
          <div
            class="relative text-center animate-on-scroll"
            style={`transition-delay: ${idx * 120}ms`}
          >
            {/* Step circle */}
            <div class="relative mx-auto mb-6 flex h-16 w-16 items-center justify-center">
              <div class="absolute inset-0 rounded-full bg-gradient-to-br from-blue-600/20 to-cyan-600/20 border border-primary/30" />
              <svg
                class="relative h-7 w-7 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={stepIcons[idx]} />
              </svg>
            </div>

            {/* Step badge */}
            <span class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary">
              Krok {step.step}
            </span>

            {/* Title */}
            <h3 class="mb-2 text-xl font-semibold text-foreground">
              {step.title}
            </h3>

            {/* Description */}
            <p class="text-[0.925rem] leading-relaxed text-muted-foreground">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
