---
import { pl } from "../i18n/pl";
const i = pl.hero;
---

<section
  class="relative overflow-hidden gradient-mesh-strong pt-28 pb-20 sm:pt-36 sm:pb-28"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Badge -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1.5">
        <div class="h-2 w-2 rounded-full bg-primary animate-pulse"></div>
        <span class="text-xs font-semibold text-primary">
          Wersja Early Access
        </span>
      </div>

      <!-- H1 -->
      <h1
        class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl"
      >
        <span class="block text-foreground">{i.line1}</span>
        <span class="block text-gradient">{i.line2}</span>
      </h1>

      <!-- Subtitle -->
      <p
        class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground sm:text-xl"
      >
        {i.subtitle}
      </p>

      <!-- CTA Pair -->
      <div
        class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
      >
        <a
          href="https://calendly.com/hello-awesomeworks/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-cyan-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-blue-500/25 transition-all hover:shadow-xl hover:shadow-blue-500/30 hover:brightness-110"
        >
          {i.ctaPrimary}
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-2 rounded-xl border border-white/[0.1] bg-white/[0.04] px-8 py-3.5 text-base font-semibold text-foreground transition-all hover:bg-white/[0.08]"
        >
          {i.ctaSecondary}
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
      </div>

      <!-- Micro-copy -->
      <p class="mt-4 text-sm text-muted-foreground">{i.micro}</p>
    </div>

    <!-- Hero Visual — App mockup -->
    <div class="mx-auto mt-16 max-w-4xl animate-float">
      <div
        class="overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.03] p-1.5 shadow-2xl shadow-blue-500/10"
      >
        <div class="rounded-xl bg-white/[0.02] p-6 sm:p-8">
          <!-- Mock invoice dekretacja flow -->
          <div class="space-y-4">
            <!-- Invoice card -->
            <div class="flex items-start gap-3 rounded-xl border border-white/[0.06] bg-white/[0.03] p-4">
              <div class="flex-shrink-0 rounded-lg bg-primary/10 border border-primary/20 p-2">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between">
                  <p class="text-sm font-semibold text-foreground">FV/2026/02/045</p>
                  <span class="text-xs text-muted-foreground">1 230,00 zł</span>
                </div>
                <p class="text-xs text-muted-foreground mt-0.5">Hurtownia ABC — materiały biurowe</p>
              </div>
            </div>

            <!-- AI dekretacja result -->
            <div class="rounded-xl border border-primary/20 bg-primary/5 p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></div>
                <p class="text-xs font-semibold text-primary">Dekret zaproponowany</p>
                <span class="ml-auto inline-flex items-center rounded-full bg-green-500/10 border border-green-500/20 px-2 py-0.5 text-xs text-green-400">95%</span>
              </div>
              <div class="space-y-1.5 text-xs text-foreground/80">
                <div class="flex justify-between">
                  <span>Kolumna KPiR:</span>
                  <span class="font-medium text-foreground">13 — Pozostałe wydatki</span>
                </div>
                <div class="flex justify-between">
                  <span>VAT naliczony:</span>
                  <span class="font-medium text-foreground">230,00 zł (100%)</span>
                </div>
                <div class="flex justify-between">
                  <span>KUP:</span>
                  <span class="font-medium text-foreground">1 000,00 zł (100%)</span>
                </div>
              </div>
              <div class="mt-3 flex gap-2">
                <button class="flex-1 rounded-lg bg-gradient-to-r from-blue-600 to-cyan-600 px-3 py-1.5 text-xs font-semibold text-white">
                  ✅ Zatwierdź
                </button>
                <button class="rounded-lg border border-white/[0.1] bg-white/[0.04] px-3 py-1.5 text-xs text-foreground">
                  ✏️ Popraw
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
