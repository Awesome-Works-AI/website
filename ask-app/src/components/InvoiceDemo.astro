---
import { pl } from "../i18n/pl";
const i = pl.invoiceDemo;
---

<section
  id="invoice-demo"
  class="relative overflow-hidden gradient-mesh py-20 sm:py-28"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center animate-on-scroll">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1.5">
        <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <span class="text-xs font-semibold text-primary">{i.badge}</span>
      </div>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {i.title}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        {i.subtitle}
      </p>
    </div>

    <!-- Demo Container -->
    <div class="mx-auto max-w-3xl animate-on-scroll" style="transition-delay: 100ms">
      <div class="overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.03] shadow-2xl shadow-blue-500/10">

        <!-- Chat Header -->
        <div class="flex items-center gap-3 border-b border-white/[0.06] px-6 py-4">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-blue-600 to-cyan-600">
            <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-foreground">{i.header.title}</p>
            <p class="text-xs text-muted-foreground">{i.header.subtitle}</p>
          </div>
          <div class="ml-auto flex items-center gap-1.5">
            <div class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></div>
            <span class="text-xs text-green-400">{i.header.status}</span>
          </div>
        </div>

        <!-- Chat Body -->
        <div class="space-y-4 p-6" id="invoice-demo-chat">

          <!-- User Message -->
          <div class="flex justify-end demo-msg" data-delay="0">
            <div class="max-w-[85%] rounded-2xl rounded-br-md bg-gradient-to-r from-blue-600 to-cyan-600 px-5 py-3 shadow-lg shadow-blue-500/15">
              <p class="text-sm leading-relaxed text-white">{i.userMessage}</p>
            </div>
          </div>

          <!-- Agent Thinking Steps -->
          {i.agentSteps.map((step, idx) => (
            <div class="flex items-start gap-3 demo-msg" data-delay={((idx + 1) * 600).toString()}>
              <div class="flex-shrink-0 mt-0.5">
                <div class="flex h-7 w-7 items-center justify-center rounded-full bg-white/[0.06] border border-white/[0.08]">
                  <svg class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                  </svg>
                </div>
              </div>
              <div class="flex items-center gap-2 rounded-xl border border-white/[0.06] bg-white/[0.03] px-4 py-2.5">
                <div class={`h-2 w-2 rounded-full flex-shrink-0 ${step.done ? 'bg-green-400' : 'bg-blue-400 animate-pulse'}`}></div>
                <p class="text-sm text-muted-foreground">{step.text}</p>
                {step.done && (
                  <svg class="h-4 w-4 flex-shrink-0 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                )}
              </div>
            </div>
          ))}

          <!-- Invoice Preview Card -->
          <div class="demo-msg" data-delay={(i.agentSteps.length * 600 + 600).toString()}>
            <div class="rounded-xl border border-primary/20 bg-primary/5 p-5">
              <div class="flex items-center gap-2 mb-4">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <p class="text-sm font-semibold text-primary">{i.invoice.title}</p>
                <span class="ml-auto inline-flex items-center rounded-full bg-green-500/10 border border-green-500/20 px-2.5 py-0.5 text-xs font-medium text-green-400">
                  {i.invoice.statusLabel}
                </span>
              </div>

              <!-- Invoice Details -->
              <div class="space-y-2 text-sm">
                {i.invoice.fields.map(field => (
                  <div class="flex justify-between items-baseline">
                    <span class="text-muted-foreground">{field.label}</span>
                    <span class="font-medium text-foreground">{field.value}</span>
                  </div>
                ))}
              </div>

              <!-- Divider -->
              <div class="my-4 border-t border-white/[0.08]"></div>

              <!-- Totals -->
              <div class="space-y-1.5 text-sm">
                {i.invoice.totals.map(total => (
                  <div class={`flex justify-between items-baseline ${total.highlight ? 'text-base' : ''}`}>
                    <span class={total.highlight ? 'font-semibold text-foreground' : 'text-muted-foreground'}>{total.label}</span>
                    <span class={`font-semibold ${total.highlight ? 'text-primary text-lg' : 'text-foreground'}`}>{total.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Agent Summary Message -->
          <div class="flex items-start gap-3 demo-msg" data-delay={((i.agentSteps.length + 1) * 600 + 600).toString()}>
            <div class="flex-shrink-0 mt-0.5">
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-gradient-to-br from-blue-600 to-cyan-600">
                <svg class="h-3.5 w-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                </svg>
              </div>
            </div>
            <div class="rounded-2xl rounded-bl-md border border-white/[0.06] bg-white/[0.03] px-5 py-3">
              <p class="text-sm leading-relaxed text-foreground">{i.agentSummary}</p>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="demo-msg" data-delay={((i.agentSteps.length + 2) * 600 + 600).toString()}>
            <div class="flex flex-wrap gap-3 ml-10">
              {i.actions.map(action => (
                <button class={`group inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold transition-all ${
                  action.primary
                    ? 'bg-gradient-to-r from-blue-600 to-cyan-600 text-white shadow-lg shadow-blue-500/25 hover:shadow-xl hover:shadow-blue-500/30 hover:brightness-110'
                    : 'border border-white/[0.1] bg-white/[0.04] text-foreground hover:bg-white/[0.08]'
                }`}>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={action.icon} />
                  </svg>
                  {action.label}
                </button>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Animate chat messages sequentially when section comes into view
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const messages = entry.target.querySelectorAll('.demo-msg');
          messages.forEach((msg) => {
            const el = msg as HTMLElement;
            const delay = parseInt(el.dataset.delay || '0', 10);
            setTimeout(() => {
              el.classList.add('demo-visible');
            }, delay);
          });
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 }
  );

  const chat = document.getElementById('invoice-demo-chat');
  if (chat) observer.observe(chat);
</script>

<style>
  .demo-msg {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
  .demo-msg.demo-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
