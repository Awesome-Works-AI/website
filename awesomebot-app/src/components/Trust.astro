---
import Icon from "~/components/Icon.astro";
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items: { icon: string; title: UiKey; body: UiKey }[] = [
  { icon: "user-check", title: "trust.i1.title", body: "trust.i1.body" },
  { icon: "history", title: "trust.i2.title", body: "trust.i2.body" },
  { icon: "undo-2", title: "trust.i3.title", body: "trust.i3.body" },
  { icon: "shield-check", title: "trust.i4.title", body: "trust.i4.body" },
];
---

<section class="relative overflow-hidden bg-offwhite py-20 md:py-28">
  <div aria-hidden="true" class="absolute inset-0 bg-blueprint"></div>
  <div class="relative mx-auto max-w-6xl px-6">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div>
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary-deep">
          [ {t("trust.eyebrow")} ]
        </p>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-ink md:text-5xl">
          {t("trust.heading")}
        </h2>
        <p class="mt-4 max-w-md text-lg text-muted">{t("trust.sub")}</p>
      </div>

      <div class="grid gap-x-8 gap-y-9 sm:grid-cols-2">
        {
          items.map((item) => (
            <div>
              <span class="grid h-10 w-10 place-items-center rounded-lg bg-band text-primary-deep">
                <Icon name={item.icon} class="h-5 w-5" />
              </span>
              <h3 class="mt-3.5 text-lg font-semibold tracking-tight text-ink">{t(item.title)}</h3>
              <p class="mt-1.5 text-[0.95rem] leading-relaxed text-muted">{t(item.body)}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
