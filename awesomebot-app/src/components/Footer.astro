---
import Logo from "~/components/Logo.astro";
import { getLangFromUrl, useTranslations, getLocalizedPath } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const productLinks: { href: string; key: UiKey }[] = [
  { href: "#problem", key: "nav.problem" },
  { href: "#produkt", key: "nav.product" },
  { href: "#jak-dziala", key: "nav.how" },
  { href: "#dla-kogo", key: "nav.who" },
  { href: "#cennik", key: "nav.pricing" },
  { href: "#faq", key: "nav.faq" },
];

// PL and EN legal slugs differ (regulamin ⇄ terms), so pick per-locale.
const legalSlugs =
  lang === "pl"
    ? { terms: "/regulamin", privacy: "/prywatnosc", subprocessors: "/podprocesorzy" }
    : { terms: "/terms", privacy: "/privacy", subprocessors: "/subprocessors" };
const legalLinks: { href: string; key: UiKey }[] = [
  { href: getLocalizedPath(legalSlugs.terms, lang), key: "footer.terms" },
  { href: getLocalizedPath(legalSlugs.privacy, lang), key: "footer.privacy" },
  { href: getLocalizedPath(legalSlugs.subprocessors, lang), key: "footer.subprocessors" },
];
---

<footer class="border-t border-white/10 bg-dark py-14">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5">
          <Logo class="h-7 w-7" />
          <span class="text-lg font-bold tracking-tight text-white">AwesomeBot</span>
        </div>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/70">{t("footer.tagline")}</p>
        <p class="mt-6 font-mono text-xs text-white/60">{t("footer.legal")}</p>
      </div>

      <div>
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-band-strong">
          {t("footer.product")}
        </p>
        <ul class="mt-4 space-y-2.5 text-sm text-white/70">
          {
            productLinks.map((link) => (
              <li>
                <a href={link.href} class="transition hover:text-white">
                  {t(link.key)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-band-strong">
          {t("footer.company")}
        </p>
        <ul class="mt-4 space-y-2.5 text-sm text-white/70">
          <li>
            <a href="https://awesomeworks.ai" class="transition hover:text-white">{t("footer.company.aw")}</a>
          </li>
          <li>
            <a href="mailto:hello@awesomeworks.ai" class="transition hover:text-white"
              >{t("footer.company.contact")}</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start gap-4 border-t border-white/10 pt-6 text-xs text-white/60"
    >
      <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Legal">
        {
          legalLinks.map((link) => (
            <a href={link.href} class="transition hover:text-white">
              {t(link.key)}
            </a>
          ))
        }
      </nav>
      <div
        class="flex w-full flex-col items-start justify-between gap-3 sm:flex-row sm:items-center"
      >
        <span>{t("footer.copyright")}</span>
        <a href="https://awesomeworks.ai" class="transition hover:text-white">{t("footer.madeby")}</a>
      </div>
    </div>
  </div>
</footer>
