---
// Triage case mock in HUD style — the product's proof artifact.
// Message / tag / priority / draft content swaps with the active segment.
import Icon from "~/components/Icon.astro";
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

/** Renders both segment variants; html[data-segment] decides visibility. */
const seg = (base: string) => ({
  med: `${base}.med` as UiKey,
  est: `${base}.est` as UiKey,
});

const msgLabel = seg("triage.msg.label");
const msgText = seg("triage.msg.text");
const tagValue = seg("triage.tag.value");
const linked = seg("triage.linked");
const prioValue = seg("triage.prio.value");
const prioWhy = seg("triage.prio.why");
const draftLabel = seg("triage.draft.label");
const draftText = seg("triage.draft.text");
---

<div
  class="hud-card hud-card-on rounded-xl border border-band-strong/70 bg-white p-5 text-left shadow-[0_24px_60px_-24px_color-mix(in_srgb,var(--color-dark)_25%,transparent)]"
>
  <div class="flex items-center justify-between border-b border-band pb-3">
    <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-dark">
      {t("triage.header")}
    </span>
    <span class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-wide text-primary-deep">
      <span class="status-dot"></span>
      {t("triage.online")}
    </span>
  </div>

  {/* Incoming message */}
  <div class="mt-4">
    <p class="font-mono text-[10px] font-medium uppercase tracking-[0.14em] text-muted">
      <span class="seg-med">{t(msgLabel.med)}</span><span class="seg-est">{t(msgLabel.est)}</span>
    </p>
    <div class="mt-1.5 flex items-start gap-2.5 rounded-lg bg-band/70 p-3">
      <Icon name="message-square" class="mt-0.5 h-4 w-4 flex-none text-primary-deep" />
      <p class="text-sm leading-snug text-ink">
        <span class="seg-med">{t(msgText.med)}</span><span class="seg-est">{t(msgText.est)}</span>
      </p>
    </div>
  </div>

  {/* Tag + priority */}
  <div class="mt-4 grid grid-cols-2 gap-3">
    <div>
      <p class="font-mono text-[10px] font-medium uppercase tracking-[0.14em] text-muted">
        {t("triage.tag.label")}
      </p>
      <span class="mt-1.5 inline-flex items-center gap-1.5 rounded-md border border-band-strong bg-white px-2 py-1 text-xs font-medium text-dark">
        <Icon name="tag" class="h-3.5 w-3.5 text-primary" />
        <span class="seg-med">{t(tagValue.med)}</span><span class="seg-est">{t(tagValue.est)}</span>
      </span>
      <p class="mt-1.5 text-[11px] text-muted">
        <span class="seg-med">{t(linked.med)}</span><span class="seg-est">{t(linked.est)}</span>
      </p>
    </div>
    <div>
      <p class="font-mono text-[10px] font-medium uppercase tracking-[0.14em] text-muted">
        {t("triage.prio.label")}
      </p>
      <span class="mt-1.5 inline-flex items-center gap-1.5 rounded-md bg-dark px-2 py-1 font-mono text-xs font-semibold uppercase tracking-wide text-band-strong">
        <Icon name="zap" class="h-3.5 w-3.5" />
        <span class="seg-med">{t(prioValue.med)}</span><span class="seg-est">{t(prioValue.est)}</span>
      </span>
      <p class="mt-1.5 text-[11px] text-muted">
        <span class="seg-med">{t(prioWhy.med)}</span><span class="seg-est">{t(prioWhy.est)}</span>
      </p>
    </div>
  </div>

  {/* Draft reply */}
  <div class="mt-4">
    <p class="font-mono text-[10px] font-medium uppercase tracking-[0.14em] text-muted">
      <span class="seg-med">{t(draftLabel.med)}</span><span class="seg-est">{t(draftLabel.est)}</span>
    </p>
    <p class="mt-1.5 rounded-lg border border-dashed border-band-strong/80 p-3 text-sm leading-snug text-muted">
      <span class="seg-med">{t(draftText.med)}</span><span class="seg-est">{t(draftText.est)}</span>
    </p>
  </div>

  {/* Approval bar */}
  <div class="mt-4 flex items-center justify-between rounded-lg bg-offwhite px-3 py-2.5">
    <span class="inline-flex items-center gap-2 text-xs text-muted">
      <Icon name="user-check" class="h-4 w-4 text-primary-deep" />
      {t("triage.approval")}
    </span>
    <span class="inline-flex items-center gap-1.5 rounded-full bg-gradient-to-br from-cta to-cta-deep px-3 py-1.5 text-xs font-semibold text-white">
      <Icon name="check" class="h-3.5 w-3.5" />
      {t("triage.approve")}
    </span>
  </div>
</div>
