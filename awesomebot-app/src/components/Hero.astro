---
// Hero: segment toggle centered on the page axis, then a two-column stage —
// copy + bare phone demo on the left, the orb light sculpture with floating
// message chips on the right. Fits one desktop viewport.
import Icon from "~/components/Icon.astro";
import SegmentToggle from "~/components/SegmentToggle.astro";
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Shared booking fallback — also the CTA on demo-call error states.
const CALENDLY_URL = "https://calendly.com/hello-awesomeworks/30min";

// Floating chips: [medical key, estate key, icon, position classes, cycle vars, mobile visibility]
const chips: { med: UiKey; est: UiKey; icon: string; pos: string; vars: string; mobile: boolean }[] = [
  {
    med: "chips.med.1",
    est: "chips.est.1",
    icon: "message-square",
    pos: "top-[8%] left-[-4%] lg:left-[-10%]",
    vars: "--cd: 14s; --cdelay: 0s;",
    mobile: true,
  },
  {
    med: "chips.med.2",
    est: "chips.est.2",
    icon: "mail",
    pos: "top-[30%] right-[-6%] lg:right-[-14%]",
    vars: "--cd: 18s; --cdelay: 5s;",
    mobile: true,
  },
  {
    med: "chips.med.3",
    est: "chips.est.3",
    icon: "phone",
    pos: "bottom-[10%] left-[4%] lg:left-[-6%]",
    vars: "--cd: 20s; --cdelay: 10s;",
    mobile: false,
  },
];

// Orbiting sparks: radius / duration / start angle / delay
const sparks = [
  "--r: 0.44; --d: 14s; --a: 0deg; --delay: 0s;",
  "--r: 0.39; --d: 19s; --a: 120deg; --delay: -4s;",
  "--r: 0.48; --d: 23s; --a: 230deg; --delay: -9s;",
  "--r: 0.34; --d: 17s; --a: 65deg; --delay: -12s;",
  "--r: 0.51; --d: 29s; --a: 300deg; --delay: -6s;",
];
---

<section class="relative overflow-hidden">
  {/* Background layer — off-white + blueprint grid, diagonally cut bottom edge */}
  <div aria-hidden="true" class="diag-bottom absolute inset-0 bg-offwhite">
    <div class="absolute inset-0 bg-blueprint"></div>
    {/* drifting corner blobs + faint light streaks, segment-tinted */}
    <div class="hero-blob absolute -top-24 -right-24 h-96 w-96 bg-primary-bright/15"></div>
    <div class="hero-blob absolute -bottom-32 -left-24 h-96 w-96 bg-band-strong/20 [animation-delay:-13s]"></div>
    <div class="hero-light-streak absolute top-24 -left-10 w-72 -rotate-[24deg]"></div>
    <div class="hero-light-streak absolute bottom-32 -right-8 w-80 -rotate-[24deg]"></div>
  </div>

  <div
    class="relative mx-auto flex max-w-6xl flex-col px-6 pt-24 pb-16 md:pt-28 lg:min-h-svh lg:justify-center lg:pt-24 lg:pb-10"
  >
    {/* Segment toggle — centered on the page axis, above the two-column stage */}
    <div class="relative z-10 flex justify-center">
      <SegmentToggle />
    </div>

    <div class="relative mt-10 grid items-center gap-10 lg:mt-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-6">
      {/* Left — copy + phone demo (above the dimmed orb on mobile) */}
      <div class="relative z-10 flex flex-col items-start text-left">
        {/* Live status log — cycling reception feed, no badge chrome */}
        <p class="flex items-center gap-2.5 font-mono text-xs font-medium text-primary-deep" aria-hidden="true">
          <span class="status-dot"></span>
          <span class="status-log seg-med">
            <span>{t("hero.log.med.1")}</span>
            <span>{t("hero.log.med.2")}</span>
            <span>{t("hero.log.med.3")}</span>
          </span>
          <span class="status-log seg-est">
            <span>{t("hero.log.est.1")}</span>
            <span>{t("hero.log.est.2")}</span>
            <span>{t("hero.log.est.3")}</span>
          </span>
        </p>

        <h1 class="mt-6 max-w-xl text-4xl font-bold leading-[1.05] tracking-tight text-ink sm:text-5xl xl:text-[4.25rem]">
          <span class="seg-med">{t("hero.h1.pre.med")}</span><span class="seg-est">{t("hero.h1.pre.est")}</span>
          <span class="text-primary underline decoration-band-strong decoration-[3px] underline-offset-8">
            <span class="seg-med">{t("hero.h1.accent.med")}</span><span class="seg-est">{t("hero.h1.accent.est")}</span></span
          >.
        </h1>

        {/* Phone demo — with PUBLIC_AWESOMEBOT_API_BASE set at build time the form POSTs
            to the AwesomeBot backend and places a real outbound AI call; with the variable
            empty it is a client-only stub (digit validation + "coming soon" note). */}
        <form class="mt-9 w-full max-w-md" novalidate data-demo-form data-lang={lang}>
          <div class="flex items-stretch gap-2">
            <span
              class="inline-flex flex-none cursor-help items-center gap-1.5 rounded-full border border-band-strong/60 bg-white/80 px-3.5 font-mono text-sm font-medium text-ink backdrop-blur-sm"
              title={t("phone.prefix.title")}
            >
              {/* Polish flag — inline SVG (no emoji, renders everywhere) */}
              <svg viewBox="0 0 20 14" class="h-3.5 w-5 flex-none overflow-hidden rounded-[2px]" aria-hidden="true">
                <rect width="20" height="7" y="0" fill="#f5f5f5"></rect>
                <rect width="20" height="7" y="7" fill="#dc143c"></rect>
              </svg>
              +48
            </span>
            <input
              type="tel"
              inputmode="tel"
              autocomplete="tel-national"
              placeholder={t("phone.input.placeholder")}
              aria-label={t("phone.input.label")}
              class="h-12 w-full min-w-0 rounded-full border border-band-strong/60 bg-white/80 px-5 font-mono text-sm text-ink backdrop-blur-sm placeholder:text-muted/60 focus:border-primary focus:outline-none"
            />
          </div>
          {/* Honeypot — bots fill it and get a fake success from the backend; people never
              see it (offscreen via .hp-field, out of the tab order and the a11y tree). */}
          <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp-field" />
          <button type="submit" class="btn-primary mt-3 w-full">
            <Icon name="phone" class="h-4 w-4" />
            <span class="btn-dot hidden" data-demo-cta-dot aria-hidden="true"></span>
            <span data-demo-cta-label>{t("phone.cta")}</span>
          </button>
          <p class="mt-2 text-left text-xs leading-snug text-muted">{t("phone.consent")}</p>
          <p
            class="mt-3 hidden text-left text-sm leading-snug text-primary-deep"
            data-demo-success
            role="status"
            aria-live="polite"
          >
            <span data-demo-success-text>{t("phone.success")}</span>
            <a
              href={CALENDLY_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold underline decoration-band-strong decoration-2 underline-offset-2 hover:text-ink hover:decoration-primary"
              data-demo-success-link
              >{t("phone.success.link")} ↗</a
            >
          </p>
          <p
            class="mt-3 hidden text-left text-sm leading-snug text-danger"
            data-demo-error
            role="alert"
            aria-live="polite"
          >
            <span data-demo-error-text>{t("phone.error")}</span>
            <a
              href={CALENDLY_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden font-semibold text-ink underline decoration-band-strong decoration-2 underline-offset-2 hover:decoration-primary"
              data-demo-error-link
              >{t("phone.success.link")} ↗</a
            >
          </p>
        </form>

        <div class="mt-5 flex flex-wrap items-baseline gap-x-5 gap-y-1">
          <a
            href={CALENDLY_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-ink underline decoration-band-strong decoration-2 underline-offset-4 transition hover:decoration-primary"
          >
            {t("hero.demolink")} ↗
          </a>
          <p class="hero-micro font-mono text-xs text-muted">{t("hero.micro")}</p>
        </div>
      </div>

      {/* Right — orb light sculpture + floating message chips.
          Mobile: sits dimmed behind the left column (decoration only). */}
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-40 lg:static lg:opacity-100"
      >
        <div class="relative">
          <div class="orb [--orb-size:260px] md:[--orb-size:320px] xl:[--orb-size:380px]">
            <div class="orb-halo"></div>
            <div class="orb-halo-2"></div>
            <div class="orb-body">
              <div class="orb-aura"></div>
              <div class="orb-streak orb-streak-1"></div>
              <div class="orb-streak orb-streak-2"></div>
              <div class="orb-streak orb-streak-3"></div>
              <div class="orb-streak orb-streak-4"></div>
              <div class="orb-comet"></div>
              <div class="orb-ring"></div>
              <div class="orb-core"></div>
              {sparks.map((s) => <div class="orb-spark" style={s}></div>)}
              <div class="orb-grain"></div>
            </div>
          </div>

          {/* Messages drifting into the front desk */}
          {
            chips.map((c) => (
              <div
                class:list={["orb-chip", c.mobile ? "inline-flex" : "hidden lg:inline-flex", c.pos]}
                style={c.vars}
              >
                <Icon name={c.icon} class="h-3.5 w-3.5 flex-none text-primary-deep" />
                <span class="seg-med">{t(c.med)}</span>
                <span class="seg-est">{t(c.est)}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { ui, defaultLang, type UiKey } from "~/i18n/ui";

  // Build-time switch: with PUBLIC_AWESOMEBOT_API_BASE unset/empty the form is a
  // client-only stub — digit validation + the "coming soon" note, no request ever
  // leaves the page. Setting the variable at build time flips it to the live demo
  // call: POST {API_BASE}/v1/public/demo-call (AwesomeBot backend, TD-6).
  const API_BASE = (import.meta.env.PUBLIC_AWESOMEBOT_API_BASE ?? "").replace(/\/+$/, "");
  const FETCH_TIMEOUT_MS = 12_000;
  const RESUBMIT_HOLD_MS = 60_000;

  // Backend error code → i18n key (contract: TD-6 §2.3 / §7.2). Field-level codes
  // render without the Calendly CTA; unknown codes fall back to the generic message.
  const ERROR_KEY_BY_CODE: Record<string, UiKey> = {
    invalid_phone: "phone.error",
    unsupported_prefix: "phone.error",
    cooldown_active: "phone.error.cooldown",
    phone_daily_limit: "phone.error.capacity",
    ip_daily_limit: "phone.error.capacity",
    daily_cap_reached: "phone.error.capacity",
    demo_unavailable: "phone.error.capacity",
  };

  document.querySelectorAll<HTMLFormElement>("[data-demo-form]").forEach((form) => {
    const lang: keyof typeof ui = form.dataset.lang === "en" ? "en" : defaultLang;
    const t = (key: UiKey): string => ui[lang][key] ?? ui[defaultLang][key];

    const input = form.querySelector<HTMLInputElement>("input[type='tel']");
    const honeypot = form.querySelector<HTMLInputElement>("input[name='website']");
    const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
    const icon = button?.querySelector("svg");
    const dot = button?.querySelector<HTMLElement>("[data-demo-cta-dot]");
    const label = button?.querySelector<HTMLElement>("[data-demo-cta-label]");
    const success = form.querySelector<HTMLElement>("[data-demo-success]");
    const successText = form.querySelector<HTMLElement>("[data-demo-success-text]");
    const successLink = form.querySelector<HTMLElement>("[data-demo-success-link]");
    const error = form.querySelector<HTMLElement>("[data-demo-error]");
    const errorText = form.querySelector<HTMLElement>("[data-demo-error-text]");
    const errorLink = form.querySelector<HTMLElement>("[data-demo-error-link]");

    let holdTimer: ReturnType<typeof setTimeout> | undefined;

    const setDisabled = (disabled: boolean) => {
      if (!button) return;
      // Keep keyboard focus alive when the focused button gets disabled (a11y).
      if (disabled && document.activeElement === button) input?.focus();
      button.disabled = disabled;
    };

    const setBusy = (busy: boolean) => {
      icon?.classList.toggle("hidden", busy);
      dot?.classList.toggle("hidden", !busy);
      dot?.classList.toggle("inline-block", busy);
      if (label) label.textContent = busy ? t("phone.cta.loading") : t("phone.cta");
      button?.setAttribute("aria-busy", String(busy));
    };

    const holdResubmit = () => {
      clearTimeout(holdTimer);
      setDisabled(true);
      holdTimer = setTimeout(() => setDisabled(false), RESUBMIT_HOLD_MS);
    };

    const hideMessages = () => {
      success?.classList.add("hidden");
      error?.classList.add("hidden");
    };

    // Unhide first, then swap the copy — mutations inside an already-visible
    // aria-live region are announced more reliably than unhiding filled content.
    const showSuccess = (liveText?: string) => {
      hideMessages();
      success?.classList.remove("hidden");
      if (liveText && successText) successText.textContent = liveText;
      // The stub note keeps its booking link; the live "calling you" state has no CTA.
      successLink?.classList.toggle("hidden", Boolean(liveText));
    };

    const showError = (key: UiKey) => {
      hideMessages();
      error?.classList.remove("hidden");
      if (errorText) errorText.textContent = t(key);
      errorLink?.classList.toggle("hidden", key === "phone.error");
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (button?.disabled) return; // Enter in the input during in-flight/lockout

      const digits = (input?.value ?? "").replace(/\D/g, "");
      if (digits.length !== 9) {
        showError("phone.error");
        return;
      }

      if (!API_BASE) {
        showSuccess(); // stub mode — pre-rendered "coming soon" note + booking link
        return;
      }

      const segment =
        document.documentElement.getAttribute("data-segment") === "estate" ? "estate" : "medical";

      hideMessages();
      setBusy(true);
      setDisabled(true);

      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);
      try {
        const res = await fetch(`${API_BASE}/v1/public/demo-call`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            phone: digits,
            segment,
            locale: form.dataset.lang ?? "pl",
            website: honeypot?.value ?? "",
          }),
          signal: controller.signal,
        });
        if (res.status === 202) {
          showSuccess(t("phone.success.calling"));
          holdResubmit();
        } else {
          const body = await res.json().catch(() => null);
          const code = body?.detail?.code;
          const key =
            (typeof code === "string" && ERROR_KEY_BY_CODE[code]) || "phone.error.generic";
          showError(key);
          if (code === "cooldown_active") holdResubmit();
          else setDisabled(false);
        }
      } catch {
        // Timeout (AbortError) and network failures share the generic path.
        showError("phone.error.generic");
        setDisabled(false);
      } finally {
        clearTimeout(timeout);
        setBusy(false);
      }
    });
  });
</script>
