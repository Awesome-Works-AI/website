---
// AwesomeBot mark — geometric bot-head hexagon with "A" (same shape as favicon).
interface Props {
  class?: string;
}

const { class: className = "h-6 w-6" } = Astro.props;
---

{/* Fills follow the active segment skin via CSS vars (favicon stays static teal). */}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class={className} aria-hidden="true">
  <path d="M32 3 57 17.5v29L32 61 7 46.5v-29Z" fill="var(--color-dark, #0F3D3E)"></path>
  <path d="M32 8 52.5 20v24L32 56 11.5 44V20Z" fill="var(--color-primary, #0D9488)"></path>
  <path
    d="M23 43 32 20l9 23M26.4 35.4h11.2"
    fill="none"
    stroke="#FFFFFF"
    stroke-width="4.5"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <circle cx="52.5" cy="13" r="4" fill="var(--color-band-strong, #7ED4C9)"></circle>
</svg>
