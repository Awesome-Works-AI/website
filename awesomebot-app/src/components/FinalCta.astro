---
import Icon from "~/components/Icon.astro";
import { getLangFromUrl, useTranslations } from "~/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="umow-rozmowe" class="diag-top scroll-mt-10 relative overflow-hidden bg-dark pb-20 md:pb-24">
  <div aria-hidden="true" class="absolute inset-0 bg-blueprint-dark"></div>
  <div class="relative mx-auto max-w-6xl px-6 pt-8 md:pt-12">
    <p class="inline-flex items-center gap-2.5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-band-strong">
      <span class="status-dot"></span>
      [ {t("cta.eyebrow")} ]
    </p>
    <h2 class="mt-5 max-w-2xl text-3xl font-bold tracking-tight text-white md:text-5xl">
      {t("cta.heading")}
    </h2>
    <p class="mt-4 max-w-xl text-lg leading-relaxed text-white/75">{t("cta.sub")}</p>

    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a
        href="https://calendly.com/hello-awesomeworks/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        {t("cta.primary")}
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
      <a
        href="mailto:hello@awesomeworks.ai?subject=AwesomeBot"
        class="inline-flex items-center justify-center gap-2 rounded-full border border-band-strong/50 bg-white/5 px-6 py-3.5 text-[0.9375rem] font-semibold text-white transition hover:border-band-strong hover:bg-white/10"
      >
        <Icon name="mail" class="h-4 w-4" />
        {t("cta.secondary")}
      </a>
    </div>
  </div>
</section>
