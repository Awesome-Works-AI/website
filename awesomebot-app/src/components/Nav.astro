---
import Logo from "~/components/Logo.astro";
import { getLangFromUrl, useTranslations, getAltLangPath, getLocalizedPath } from "~/i18n/utils";
import type { UiKey } from "~/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altLang = lang === "pl" ? "en" : "pl";
const altPath = getAltLangPath(Astro.url.pathname, altLang);
const homePath = getLocalizedPath("/", lang);

const links: { href: string; key: UiKey }[] = [
  { href: "#problem", key: "nav.problem" },
  { href: "#produkt", key: "nav.product" },
  { href: "#jak-dziala", key: "nav.how" },
  { href: "#dla-kogo", key: "nav.who" },
  { href: "#cennik", key: "nav.pricing" },
  { href: "#faq", key: "nav.faq" },
];
---

<header
  class="pointer-events-none fixed inset-x-0 top-4 z-50 flex items-center justify-between gap-3 px-4 md:px-6"
  aria-label="Primary"
>
  {/* Logo pill — top-left floating */}
  <a
    href={homePath}
    class="pointer-events-auto inline-flex items-center gap-2 rounded-full border border-band-strong/60 bg-white/85 px-3 py-2 shadow-sm backdrop-blur-md transition hover:bg-white"
  >
    <Logo class="h-6 w-6" />
    <span class="text-sm font-bold tracking-tight text-ink">AwesomeBot</span>
  </a>

  {/* Nav pill — top-right floating: anchors + language switch + CTA */}
  <nav
    class="pointer-events-auto inline-flex items-center gap-0.5 rounded-full border border-band-strong/60 bg-white/85 p-1 shadow-sm backdrop-blur-md"
  >
    {
      links.map((link) => (
        <a
          href={link.href}
          class="hidden h-9 items-center rounded-full px-3 text-[13px] font-medium text-muted transition hover:bg-band hover:text-ink lg:inline-flex"
        >
          {t(link.key)}
        </a>
      ))
    }
    <a
      href={altPath}
      class="inline-flex h-9 items-center rounded-full px-3 font-mono text-[11px] font-semibold tracking-wide text-primary-deep transition hover:bg-band hover:text-dark"
      aria-label={`Switch to ${altLang.toUpperCase()}`}>{altLang.toUpperCase()}</a
    >
    <a
      href="#umow-rozmowe"
      class="ml-0.5 inline-flex h-9 items-center rounded-full bg-gradient-to-br from-primary to-primary-deep px-4 text-xs font-semibold text-white shadow-sm transition hover:brightness-95"
      >{t("nav.cta")}</a
    >
  </nav>
</header>
