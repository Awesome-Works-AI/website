---
import "~/styles/global.css";
import Logo from "~/components/Logo.astro";
import Footer from "~/components/Footer.astro";
import { getLangFromUrl, useTranslations, getLocalizedPath } from "~/i18n/utils";

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  heading: string;
  lastUpdated: string;
  /** Clean (base-less) slug of THIS document in each locale — PL and EN slugs
   *  differ (regulamin ⇄ terms), so the generic alt-path swap can't map them.
   *  Both are needed for correct hreflang + the language switch. */
  slugs: { pl: string; en: string };
}

const { title, description, eyebrow, heading, lastUpdated, slugs } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const site = (Astro.site?.href ?? "https://awesomeworks.ai/").replace(/\/$/, "");
const plHref = site + getLocalizedPath(slugs.pl, "pl");
const enHref = site + getLocalizedPath(slugs.en, "en");
const canonical = lang === "pl" ? plHref : enHref;
const altLang = lang === "pl" ? "en" : "pl";
const altHref = lang === "pl" ? enHref : plHref;
const homePath = getLocalizedPath("/", lang);
const faviconHref = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const ogImage = `${site}${base}/og-${lang}.png`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://awesomeworks.ai/#organization",
      name: "AwesomeWorks",
      legalName: "Awesome Works AI",
      url: "https://awesomeworks.ai",
      email: "hello@awesomeworks.ai",
      taxID: "5223202536",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Warszawa",
        addressCountry: "PL",
      },
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      inLanguage: lang === "pl" ? "pl-PL" : "en",
      isPartOf: { "@id": "https://awesomeworks.ai/awesomebot/#software" },
      about: { "@id": "https://awesomeworks.ai/#organization" },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="pl" href={plHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={plHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AwesomeBot" />
    <meta property="og:locale" content={lang === "pl" ? "pl_PL" : "en_US"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-white text-ink antialiased">
    {/* Minimal legal header — logo home + language switch (no section anchors) */}
    <header
      class="pointer-events-none fixed inset-x-0 top-4 z-50 flex items-center justify-between gap-3 px-4 md:px-6"
      aria-label="Primary"
    >
      <a
        href={homePath}
        class="pointer-events-auto inline-flex items-center gap-2 rounded-full border border-band-strong/60 bg-white/85 px-3 py-2 shadow-sm backdrop-blur-md transition hover:bg-white"
      >
        <Logo class="h-6 w-6" />
        <span class="text-sm font-bold tracking-tight text-ink">AwesomeBot</span>
      </a>
      <a
        href={altHref}
        class="pointer-events-auto inline-flex h-10 items-center rounded-full border border-band-strong/60 bg-white/85 px-4 font-mono text-[11px] font-semibold tracking-wide text-primary-deep shadow-sm backdrop-blur-md transition hover:bg-white hover:text-dark"
        aria-label={`Switch to ${altLang.toUpperCase()}`}>{altLang.toUpperCase()}</a
      >
    </header>

    <main>
      <article class="legal">
        <header class="legal-head">
          <p class="legal-eyebrow">{eyebrow}</p>
          <h1 class="legal-title">{heading}</h1>
          <div class="legal-meta">
            <span class="legal-pill">{lastUpdated}</span>
            <a class="legal-pill legal-pill-link" href="mailto:hello@awesomeworks.ai"
              >hello@awesomeworks.ai</a
            >
          </div>
        </header>
        <div class="legal-prose">
          <slot />
        </div>
        <footer class="legal-foot">
          <a href={homePath} class="legal-back">← {t("legal.back")}</a>
        </footer>
      </article>
    </main>
    <Footer />

    <style>
      .legal {
        max-width: 46rem;
        margin-inline: auto;
        padding: 8.5rem 1.5rem 5rem;
      }

      .legal-head {
        padding-bottom: 2rem;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid color-mix(in srgb, var(--color-band-strong) 45%, transparent);
      }

      .legal-eyebrow {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-primary-deep);
      }

      .legal-title {
        margin-top: 0.9rem;
        font-size: clamp(1.9rem, 4vw, 2.6rem);
        font-weight: 700;
        line-height: 1.12;
        letter-spacing: -0.02em;
        text-wrap: balance;
        color: var(--color-ink);
      }

      .legal-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1.4rem;
      }

      .legal-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        border: 1px solid color-mix(in srgb, var(--color-band-strong) 55%, transparent);
        background: color-mix(in srgb, var(--color-band) 40%, #fff);
        padding: 0.35rem 0.85rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--color-muted);
      }

      .legal-pill-link {
        transition: color 0.2s ease, border-color 0.2s ease;
      }

      .legal-pill-link:hover {
        color: var(--color-primary-deep);
        border-color: var(--color-primary);
      }

      /* ---- prose ---- */
      .legal-prose {
        font-size: 1rem;
        line-height: 1.7;
        color: var(--color-ink);
      }

      .legal-prose :global(h2) {
        margin-top: 2.75rem;
        margin-bottom: 0.9rem;
        font-size: 1.28rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1.3;
        text-wrap: balance;
        color: var(--color-ink);
      }

      .legal-prose :global(h2 .legal-num) {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-band-strong);
        margin-right: 0.55rem;
      }

      .legal-prose :global(h3) {
        margin-top: 1.9rem;
        margin-bottom: 0.6rem;
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--color-ink);
      }

      .legal-prose :global(p) {
        margin-bottom: 1rem;
        color: var(--color-muted);
      }

      .legal-prose :global(strong) {
        color: var(--color-ink);
        font-weight: 600;
      }

      .legal-prose :global(a) {
        color: var(--color-primary-deep);
        text-decoration: underline;
        text-underline-offset: 2px;
        text-decoration-thickness: 1px;
      }

      .legal-prose :global(a:hover) {
        color: var(--color-primary);
      }

      .legal-prose :global(ul),
      .legal-prose :global(ol) {
        margin: 0.4rem 0 1.2rem;
        padding-left: 1.3rem;
        color: var(--color-muted);
      }

      .legal-prose :global(li) {
        margin-bottom: 0.5rem;
      }

      .legal-prose :global(li::marker) {
        color: var(--color-band-strong);
      }

      .legal-prose :global(.legal-lead) {
        font-size: 1.075rem;
        line-height: 1.65;
        color: var(--color-ink);
      }

      /* callout — key definitions / entity block */
      .legal-prose :global(.legal-card) {
        margin: 1.4rem 0;
        padding: 1.1rem 1.25rem;
        border: 1px solid color-mix(in srgb, var(--color-band-strong) 45%, transparent);
        border-left: 3px solid var(--color-primary);
        border-radius: 0.6rem;
        background: color-mix(in srgb, var(--color-band) 30%, #fff);
      }

      .legal-prose :global(.legal-card p:last-child) {
        margin-bottom: 0;
      }

      /* table (subprocessors) */
      .legal-prose :global(.legal-table-wrap) {
        margin: 1.4rem 0;
        overflow-x: auto;
        border: 1px solid color-mix(in srgb, var(--color-band-strong) 45%, transparent);
        border-radius: 0.7rem;
      }

      .legal-prose :global(table) {
        width: 100%;
        min-width: 44rem;
        border-collapse: collapse;
        font-size: 0.875rem;
      }

      .legal-prose :global(thead th) {
        background: color-mix(in srgb, var(--color-band) 55%, #fff);
        text-align: left;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-primary-deep);
        padding: 0.7rem 0.9rem;
        border-bottom: 1px solid color-mix(in srgb, var(--color-band-strong) 45%, transparent);
      }

      .legal-prose :global(tbody td) {
        padding: 0.75rem 0.9rem;
        vertical-align: top;
        color: var(--color-muted);
        border-bottom: 1px solid color-mix(in srgb, var(--color-band) 80%, transparent);
      }

      .legal-prose :global(tbody tr:last-child td) {
        border-bottom: none;
      }

      .legal-prose :global(tbody td strong) {
        color: var(--color-ink);
      }

      .legal-foot {
        margin-top: 3.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid color-mix(in srgb, var(--color-band-strong) 45%, transparent);
      }

      .legal-back {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--color-primary-deep);
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .legal-back:hover {
        color: var(--color-primary);
      }
    </style>
  </body>
</html>
