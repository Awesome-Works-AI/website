# Frontend build-time configuration for the AwesomeBot landing.
# Public vars are exposed to the browser (PUBLIC_ prefix is required).
# Copy to `.env` for local dev. In CI/CD set as env vars on the workflow.

# Backend origin for the hero demo-call form (POST {base}/v1/public/demo-call).
# Empty → stub mode: the form validates locally and shows the "coming soon" note,
# nothing is sent. Set to the public backend URL including its /api prefix
# (the backend's CORS allow-list already covers localhost:4321 for local dev).
PUBLIC_AWESOMEBOT_API_BASE=
