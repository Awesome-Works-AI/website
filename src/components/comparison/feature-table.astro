---
interface TableRow {
  feature: string;
  callwise: string;
  competitor: string;
}

interface Props {
  title?: string;
  callwiseLabel?: string;
  competitorLabel: string;
  rows: TableRow[];
}

const {
  title,
  callwiseLabel = "CallWise",
  competitorLabel,
  rows,
} = Astro.props;

function formatCell(value: string): string {
  if (value.startsWith("✅")) {
    return `<span style="color: hsl(160 59% 52%); font-weight: 600;">${value}</span>`;
  }
  if (value.startsWith("❌")) {
    return `<span style="color: hsl(0 70% 55%);">${value}</span>`;
  }
  return `<span style="color: hsl(240 10% 65%);">${value}</span>`;
}
---

<section class="relative py-20 sm:py-28">
  <div class="pointer-events-none absolute inset-0 gradient-mesh"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    {title && (
      <h2
        class="animate-on-scroll mb-12 text-center text-3xl font-bold tracking-tight sm:text-4xl"
      >
        {title}
      </h2>
    )}

    <div class="animate-on-scroll overflow-x-auto rounded-xl border border-white/[0.06] bg-white/[0.02]">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-white/[0.08]">
            <th class="px-6 py-4 text-sm font-semibold text-muted-foreground">
              {/* empty for feature column */}
            </th>
            <th class="px-6 py-4 text-center">
              <span class="text-sm font-bold text-gradient">{callwiseLabel}</span>
            </th>
            <th class="px-6 py-4 text-center">
              <span class="text-sm font-semibold text-muted-foreground">{competitorLabel}</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, idx) => (
            <tr
              class:list={[
                "border-b border-white/[0.04] transition-colors hover:bg-white/[0.02]",
                idx % 2 === 0 ? "bg-white/[0.01]" : "",
              ]}
            >
              <td class="px-6 py-4 text-sm font-medium text-foreground">
                {row.feature}
              </td>
              <td class="px-6 py-4 text-center text-sm text-muted-foreground">
                <Fragment set:html={formatCell(row.callwise)} />
              </td>
              <td class="px-6 py-4 text-center text-sm text-muted-foreground">
                <Fragment set:html={formatCell(row.competitor)} />
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>


