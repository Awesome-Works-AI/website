---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaUrl: string;
  features?: string[];
}

const { title, subtitle, ctaText, ctaUrl, features } = Astro.props;
---

<section class="relative py-20 sm:py-28">
  <div class="pointer-events-none absolute inset-0 gradient-mesh-strong"></div>

  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2
      class="animate-on-scroll mb-4 text-3xl font-bold tracking-tight sm:text-4xl"
    >
      {title}
    </h2>
    <p class="animate-on-scroll mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
      {subtitle}
    </p>

    {features && features.length > 0 && (
      <div class="animate-on-scroll mx-auto mb-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground">
        {features.map((f) => (
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {f}
          </span>
        ))}
      </div>
    )}

    <a
      href={ctaUrl}
      class="animate-on-scroll group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-indigo-400 px-10 py-4 text-lg font-semibold text-white shadow-lg shadow-indigo-500/25 transition-all hover:shadow-xl hover:shadow-indigo-500/30 hover:brightness-110"
    >
      {ctaText}
      <svg
        class="h-5 w-5 transition-transform group-hover:translate-x-0.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>
  </div>
</section>
