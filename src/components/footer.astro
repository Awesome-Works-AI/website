---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { footer } = getPersonalHome(locale);
---

<footer class="border-t border-white/[0.06] bg-white/[0.02] py-8">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <div>
      <div class="text-sm font-semibold text-foreground">Rafał Łazicki / AwesomeWorks</div>
      <p class="mt-2 max-w-xl text-sm leading-relaxed text-muted-foreground">{footer.tagline}</p>
    </div>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
      <div>
        <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-muted-foreground/70">
          {footer.legal}
        </div>
        <div class="mt-2 flex flex-wrap gap-4">
          {
            footer.legalLinks.map((link) => (
              <a
                href={link.href}
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
      <p class="text-sm text-muted-foreground/70">{footer.copyright}</p>
    </div>
  </div>
</footer>
