---
import { t, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const products = [
  {
    name: "CallWise",
    href: "https://callwise.awesomeworks.ai",
    logo: "/callwise-logo.png",
    featured: true,
    ...i.products.callwise,
  },
  {
    name: "Ask",
    href: "https://ask.awesomeworks.ai",
    logo: "/ask-logo.png",
    featured: false,
    ...i.products.ask,
  },
  {
    name: "LLM Goose",
    href: "https://github.com/Raff-dev/goose",
    logo: null,
    featured: false,
    ...i.products.goose,
  },
];

const [featuredProduct, askProduct, gooseProduct] = products;
---

<section id="products" class="relative py-20 sm:py-28">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-end gap-8 lg:grid-cols-12">
      <div class="animate-on-scroll lg:col-span-7">
        <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/60">
          {i.products.eyebrow}
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          {i.products.title}
        </h2>
      </div>
      <div class="animate-on-scroll lg:col-span-5">
        <p class="max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg">
          {i.products.subtitle}
        </p>
      </div>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-12">
      <article class="animate-on-scroll lg:col-span-7">
        <div class="rounded-[1.75rem] border border-white/[0.08] bg-white/[0.02] p-8 sm:p-10">
          <div class="flex items-center gap-4">
            <img
              src={featuredProduct.logo!}
              alt={featuredProduct.name}
              class="h-14 w-auto"
              width="62"
              height="63"
            />
            <div class="min-w-0">
              <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/55">
                {featuredProduct.label}
              </div>
              <h3 class="mt-2 text-2xl font-bold text-foreground sm:text-3xl">
                {featuredProduct.name}
              </h3>
            </div>
          </div>

          <p class="mt-6 text-xl font-semibold leading-snug text-foreground">
            {featuredProduct.tagline}
          </p>
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">
            {featuredProduct.description}
          </p>

          <div class="mt-8 grid gap-5 border-t border-white/[0.08] pt-5 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
            <p class="text-sm leading-relaxed text-muted-foreground">{featuredProduct.microcopy}</p>
            <a
              href={featuredProduct.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-full bg-indigo-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-400"
            >
              {featuredProduct.cta}
            </a>
          </div>
        </div>
      </article>

      <div class="lg:col-span-5">
        <div class="space-y-8">
          <article class="animate-on-scroll border-t border-white/[0.08] pt-6">
            <div class="flex items-center gap-4">
              <img
                src={askProduct.logo!}
                alt={askProduct.name}
                class="h-12 w-auto"
                width="56"
                height="56"
              />
              <div>
                <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/55">
                  {askProduct.label}
                </div>
                <h3 class="mt-2 text-xl font-semibold text-foreground">{askProduct.name}</h3>
              </div>
            </div>

            <p class="mt-5 text-lg font-semibold leading-snug text-foreground">
              {askProduct.tagline}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
              {askProduct.description}
            </p>
            <div class="mt-4 text-sm text-muted-foreground/80">{askProduct.microcopy}</div>

            <a
              href={askProduct.href}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex text-sm font-semibold text-foreground/80 underline underline-offset-4 decoration-border transition-colors hover:text-foreground hover:decoration-emerald-500"
            >
              {askProduct.cta}
            </a>
          </article>

          <article class="animate-on-scroll rounded-[1.5rem] border border-white/[0.08] bg-gray-950 px-6 py-6 text-white/80" style="transition-delay: 120ms">
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="text-xs font-medium uppercase tracking-[0.2em] text-white/40">
                  {gooseProduct.label}
                </div>
                <h3 class="mt-2 text-xl font-semibold text-white">{gooseProduct.name}</h3>
              </div>
              <div class="inline-flex items-center rounded-full border border-white/10 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-emerald-300/80">
                OSS
              </div>
            </div>

            <p class="mt-5 text-lg font-semibold leading-snug text-white">
              {gooseProduct.tagline}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-white/60">
              {gooseProduct.description}
            </p>

            <div class="mt-5 border-t border-white/10 pt-4 text-sm text-white/55">
              {gooseProduct.microcopy}
            </div>

            <a
              href={gooseProduct.href}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex text-sm font-semibold text-white/85 underline underline-offset-4 decoration-white/20 transition-colors hover:text-white hover:decoration-emerald-300"
            >
              {gooseProduct.cta}
            </a>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
