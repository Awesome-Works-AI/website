---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { products } = getPersonalHome(locale);

const productThemes = {
  callwise: {
    panelClass: "bg-[linear-gradient(135deg,rgba(99,102,241,0.12),rgba(255,255,255,0.03))]",
    badgeClass: "border-indigo-400/20 bg-indigo-400/10 text-indigo-200",
    buttonClass: "bg-foreground text-background hover:opacity-90",
  },
  courseai: {
    panelClass: "bg-[linear-gradient(135deg,rgba(59,130,246,0.14),rgba(34,197,94,0.06))]",
    badgeClass: "border-sky-400/20 bg-sky-400/10 text-sky-100",
    buttonClass: "bg-foreground text-background hover:opacity-90",
  },
  ask: {
    panelClass: "bg-[linear-gradient(135deg,rgba(16,185,129,0.10),rgba(255,255,255,0.02))]",
    badgeClass: "border-emerald-400/20 bg-emerald-400/10 text-emerald-200",
    buttonClass: "border border-white/[0.12] bg-white/[0.04] text-foreground hover:bg-white/[0.08]",
  },
  goose: {
    panelClass: "bg-[linear-gradient(135deg,rgba(255,255,255,0.07),rgba(2,6,23,0.7))]",
    badgeClass: "border-white/10 bg-white/[0.04] text-white/80",
    buttonClass: "border border-white/[0.14] bg-white/[0.06] text-white hover:bg-white/[0.12]",
  },
} as const;
---

{
  products.items.map((item, index) => {
    const theme = productThemes[item.id as keyof typeof productThemes];

    return (
      <section
        id={index === 0 ? "work" : undefined}
        class="presentation-slide border-t border-white/[0.06]"
      >
        <div class="presentation-shell">
          <article class={`presentation-panel animate-on-scroll ${theme.panelClass}`}>
            <div class="grid gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.7fr)] lg:items-end">
              <div class="max-w-3xl">
                <div class="section-kicker">{products.eyebrow}</div>
                {
                  index === 0 && (
                    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted-foreground">
                      {products.title} {products.subtitle}
                    </p>
                  )
                }
                <div class={`mt-6 inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] ${theme.badgeClass}`}>
                  <span>{item.label}</span>
                </div>
                <h2 class="mt-5 text-4xl font-semibold tracking-tight text-foreground sm:text-6xl">
                  {item.name}
                </h2>
                <p class="mt-5 max-w-2xl text-2xl font-medium leading-tight text-foreground/92 sm:text-3xl">
                  {item.title}
                </p>
                <p class="mt-5 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
                  {item.description}
                </p>

                <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap">
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold transition-colors ${theme.buttonClass}`}
                  >
                    {item.cta}
                  </a>
                  {
                    "secondaryHref" in item &&
                      "secondaryCta" in item &&
                      item.secondaryHref &&
                      item.secondaryCta && (
                        <a
                          href={item.secondaryHref}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
                        >
                          {item.secondaryCta}
                        </a>
                      )
                  }
                  <div class="rounded-full border border-white/[0.08] px-4 py-3 text-sm text-muted-foreground">
                    {item.note}
                  </div>
                </div>
              </div>

              <div class="grid gap-4">
                <div class="rounded-[1.5rem] border border-white/[0.08] bg-background/55 px-5 py-4 text-sm leading-relaxed text-muted-foreground">
                  {item.aside}
                </div>
                {
                  index === products.items.length - 1 && (
                    <div class="rounded-[1.5rem] border border-white/[0.08] bg-background/55 px-5 py-4 text-sm leading-relaxed text-muted-foreground">
                      {products.extra}
                    </div>
                  )
                }
              </div>
            </div>
          </article>
        </div>
      </section>
    );
  })
}
