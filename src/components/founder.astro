---
import { t, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const founder = i.team.members[0];
---

<section id="founder" class="relative border-t border-white/[0.06] py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-16">
      <div class="animate-on-scroll">
        <div class="relative mx-auto max-w-md lg:mx-0">
          <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-indigo-500/12 via-transparent to-emerald-500/10 blur-2xl" />
          <div class="relative overflow-hidden rounded-[2rem] border border-white/[0.08] bg-white/[0.03] p-3 shadow-2xl shadow-black/20">
            <img
              src={founder.photo}
              alt={founder.name}
              class="aspect-[4/5] w-full rounded-[1.5rem] object-cover object-center"
              width="720"
              height="900"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <div class="animate-on-scroll">
        <div class="mb-4 inline-flex items-center rounded-full border border-indigo-500/20 bg-indigo-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-indigo-300">
          {i.founder.eyebrow}
        </div>
        <h2 class="max-w-xl text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          {i.founder.sectionTitle}
        </h2>
        <p class="mt-5 text-sm font-medium uppercase tracking-[0.18em] text-primary">
          {founder.name} · {i.founder.role}
        </p>

        <p class="mt-6 max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg">
          {i.founder.bio}
        </p>

        <ul class="mt-8 divide-y divide-white/[0.08] border-t border-white/[0.08]">
          {
            i.founder.supportingPoints.map((point, idx) => (
              <li class="py-4 text-sm text-muted-foreground first:pt-0 last:pb-0 sm:text-base">
                <div class="text-sm font-mono text-muted-foreground/45">
                  {String(idx + 1).padStart(2, "0")}
                </div>
                <span class="mt-1 block">{point}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="https://calendly.com/hello-awesomeworks/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-indigo-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition-colors hover:bg-indigo-400"
          >
            {i.founder.cta}
          </a>
          <p class="max-w-sm text-sm text-muted-foreground">
            {i.founder.availability}
          </p>
        </div>

        <blockquote class="mt-10 max-w-xl text-xl leading-relaxed text-foreground/85 sm:text-2xl">
          “{i.founder.quote}”
        </blockquote>
        <p class="mt-3 text-sm text-muted-foreground">— {founder.name}</p>
      </div>
    </div>
  </div>
</section>
