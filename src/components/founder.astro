---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { story } = getPersonalHome(locale);
---

<section id="story" class="presentation-slide border-t border-white/[0.06]">
  <div class="presentation-shell">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(18rem,0.8fr)_minmax(0,1.15fr)] lg:gap-16">
      <div class="animate-on-scroll">
        <div class="relative mx-auto max-w-md">
          <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-indigo-500/12 via-transparent to-emerald-500/10 blur-3xl"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-white/[0.08] bg-white/[0.03] p-3 shadow-2xl shadow-black/20">
            <img
              src="/rafal.jpeg"
              alt={story.imageAlt}
              class="aspect-[4/5] w-full rounded-[1.5rem] object-cover object-center"
              width="720"
              height="900"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <div class="presentation-panel animate-on-scroll">
        <div class="section-kicker">{story.eyebrow}</div>
        <h2 class="section-title mt-4 max-w-3xl">{story.title}</h2>
        <p class="section-copy mt-6 max-w-2xl">{story.intro}</p>

        <div class="mt-8 grid gap-4">
          {
            story.points.map((point) => (
              <div class="rounded-[1.5rem] border border-white/[0.08] bg-background/50 px-5 py-4">
                <div class="text-[11px] font-semibold uppercase tracking-[0.24em] text-muted-foreground/70">
                  {point.label}
                </div>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground sm:text-base">
                  {point.text}
                </p>
              </div>
            ))
          }
        </div>

        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-foreground/88 sm:text-xl">
          {story.quote}
        </p>
      </div>
    </div>
  </div>
</section>
