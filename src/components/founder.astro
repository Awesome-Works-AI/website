---
import { t, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const [founder, ...supportTeam] = i.team.members;
---

<section id="founder" class="relative border-t border-white/[0.06] py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-16">
      <div class="animate-on-scroll">
        <div class="relative mx-auto max-w-md lg:mx-0">
          <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-indigo-500/12 via-transparent to-emerald-500/10 blur-2xl" />
          <div class="relative overflow-hidden rounded-[2rem] border border-white/[0.08] bg-white/[0.03] p-3 shadow-2xl shadow-black/20">
            <img
              src={founder.photo}
              alt={founder.name}
              class="aspect-[4/5] w-full rounded-[1.5rem] object-cover object-center"
              width="720"
              height="900"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <div class="animate-on-scroll">
        <div class="mb-4 inline-flex items-center rounded-full border border-indigo-500/20 bg-indigo-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-indigo-300">
          {i.founder.eyebrow}
        </div>
        <h2 class="max-w-xl text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          {i.founder.sectionTitle}
        </h2>

        <div class="mt-5 flex items-center gap-3">
          <div class="h-10 w-10 overflow-hidden rounded-2xl border border-white/[0.08]">
            <img
              src={founder.photo}
              alt={founder.name}
              class="h-full w-full object-cover object-center"
              width="80"
              height="80"
              loading="lazy"
            />
          </div>
          <div>
            <div class="text-base font-semibold text-foreground">{founder.name}</div>
            <div class="text-sm text-primary">{i.founder.role}</div>
          </div>
        </div>

        <p class="mt-6 max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg">
          {i.founder.bio}
        </p>

        <ul class="mt-8 space-y-3">
          {
            i.founder.supportingPoints.map((point) => (
              <li class="flex items-start gap-3 text-sm text-muted-foreground sm:text-base">
                <span class="mt-1 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-emerald-500/15 text-emerald-300">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3.5 8.5 6.5 11.5 12.5 4.5" />
                  </svg>
                </span>
                <span>{point}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-indigo-400 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition-all hover:shadow-indigo-500/35 hover:brightness-110"
          >
            {i.founder.cta}
          </a>
          <p class="text-sm text-muted-foreground">
            {i.founder.teamLabel}
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          {
            supportTeam.map((member, idx) => (
              <div
                class="rounded-2xl border border-white/[0.06] bg-white/[0.02] px-3 py-2"
                style={`transition-delay: ${120 + idx * 90}ms`}
              >
                <div class="flex items-center gap-3">
                  <img
                    src={member.photo}
                    alt={member.name}
                    class="h-11 w-11 rounded-xl border border-white/[0.06] object-cover"
                    width="44"
                    height="44"
                    loading="lazy"
                  />
                  <div>
                    <div class="text-sm font-semibold text-foreground">{member.name}</div>
                    <div class="text-xs text-muted-foreground">{member.role}</div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
