---
import { t, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const founder = i.team.members[0];
---

<section class="relative overflow-hidden bg-gray-950 py-20 sm:py-24">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(99,102,241,0.12),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.08),transparent_28%)]"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
      <div class="animate-on-scroll lg:col-span-7">
        <div class="text-xs font-medium uppercase tracking-[0.2em] text-white/45">
          {i.final_cta.eyebrow}
        </div>
        <h2 class="mt-4 max-w-3xl text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {i.final_cta.title}
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/68">
          {i.final_cta.subtitle}
        </p>

        <div class="mt-8 border-t border-white/10 pt-5">
          <div class="text-sm font-medium text-white">{founder.name}</div>
          <div class="mt-1 text-sm text-white/55">{i.founder.role}</div>
        </div>
      </div>

      <div class="animate-on-scroll lg:col-span-5">
        <div class="rounded-[1.5rem] bg-white/95 p-6 text-gray-900 sm:p-7">
          <div class="text-xs font-medium uppercase tracking-[0.2em] text-gray-500">
            {i.hero.card_label}
          </div>
          <div class="mt-5 divide-y divide-gray-200/80 border-t border-gray-200/80">
            {
              i.final_cta.points.map((point) => (
                <p class="py-4 text-sm leading-relaxed text-gray-600 first:pt-0 last:pb-0">{point}</p>
              ))
            }
          </div>

          <div class="mt-8 flex flex-col items-start gap-3">
            <a
              href="https://calendly.com/hello-awesomeworks/30min"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-full bg-gray-950 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-gray-800"
            >
              {i.final_cta.cta_primary}
            </a>
            <a
              href="#contact"
              class="text-sm font-medium text-gray-500 underline underline-offset-4 decoration-gray-300 transition-colors hover:text-gray-700 hover:decoration-emerald-500"
            >
              {i.final_cta.cta_secondary}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
