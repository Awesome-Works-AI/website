---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { socials } = getPersonalHome(locale);
---

<section id="socials" class="presentation-slide min-h-[100svh] justify-center border-t border-white/[0.06]">
  <div class="relative mx-auto flex w-full max-w-6xl items-center justify-center lg:pl-0 xl:pl-0">
    <div class="animate-on-scroll flex flex-wrap items-center justify-center gap-8 sm:gap-10">
      {
        socials.items.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={item.name}
            class="group inline-flex h-20 w-20 items-center justify-center rounded-full border border-white/[0.08] bg-white/[0.02] text-foreground/65 transition-all duration-200 hover:scale-110 hover:border-white/[0.16] hover:text-foreground sm:h-24 sm:w-24"
          >
            <span>
              {
                item.icon === "github" && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-10 w-10 fill-current sm:h-12 sm:w-12">
                    <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.58.11.79-.25.79-.56 0-.28-.01-1.2-.02-2.18-3.2.69-3.88-1.35-3.88-1.35-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.69.08-.69 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.72-1.54-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.19 1.18A10.96 10.96 0 0 1 12 6.03c.97 0 1.95.13 2.87.39 2.22-1.5 3.19-1.18 3.19-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.82 1.19 3.08 0 4.43-2.7 5.4-5.28 5.69.41.35.78 1.04.78 2.1 0 1.52-.01 2.74-.01 3.11 0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
                  </svg>
                )
              }
              {
                item.icon === "x" && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-10 w-10 fill-current sm:h-12 sm:w-12">
                    <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.24l-4.89-7.42L5.58 22H2.47l7.24-8.27L1.8 2h6.4l4.42 6.74L18.9 2Zm-1.1 18h1.73L7.26 3.9H5.4L17.8 20Z" />
                  </svg>
                )
              }
              {
                item.icon === "linkedin" && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-10 w-10 fill-current sm:h-12 sm:w-12">
                    <path d="M4.98 3.5a2.49 2.49 0 1 0 0 4.98 2.49 2.49 0 0 0 0-4.98ZM3 9h4v12H3zm7 0h3.83v1.71h.05c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.62c0-1.34-.02-3.07-1.87-3.07-1.87 0-2.16 1.46-2.16 2.97V21h-4z" />
                  </svg>
                )
              }
              {
                item.icon === "instagram" && (
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                    class="h-10 w-10 sm:h-12 sm:w-12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.9"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
                    <circle cx="12" cy="12" r="3.6"></circle>
                    <circle cx="17.2" cy="6.8" r="0.9" fill="currentColor" stroke="none"></circle>
                  </svg>
                )
              }
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
