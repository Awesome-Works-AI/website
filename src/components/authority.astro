---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { story } = getPersonalHome(locale);
---

<section
  id="story"
  class="relative flex min-h-[100svh] items-center border-t border-white/[0.06] px-5 py-20 sm:px-6 sm:py-24 lg:px-8"
>
  <div class="presentation-shell">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
      <div class="animate-on-scroll lg:col-span-5">
        <div class="section-kicker">{story.eyebrow}</div>
        <h2 class="section-title mt-4 max-w-xl">{story.title}</h2>
        {story.intro && (
          <p class="section-copy mt-5 max-w-xl">{story.intro}</p>
        )}
        {story.quote && (
          <p class="mt-6 max-w-xl border-l-2 border-red-500/60 pl-4 text-base italic leading-relaxed text-foreground/85 sm:text-lg">
            {story.quote}
          </p>
        )}
      </div>

      <div class="animate-on-scroll lg:col-span-7">
        <div class="grid gap-4 sm:grid-cols-2">
          {
            story.points.map((point, index) => (
              <article
                class="rounded-[1.5rem] border border-white/[0.08] bg-white/[0.02] p-6 shadow-xl shadow-black/10"
                style={`transition-delay: ${index * 70}ms`}
              >
                <div class="inline-flex items-center rounded-full border border-white/[0.10] bg-background/55 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-foreground/80">
                  {point.label}
                </div>
                <p class="mt-4 text-sm leading-relaxed text-muted-foreground sm:text-base">
                  {point.text}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
