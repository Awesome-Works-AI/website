---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { process } = getPersonalHome(locale);
const kicker = locale === "pl" ? "Flow" : "Flow";
---

<section id="process" class="relative flex min-h-[100svh] items-center border-t border-white/[0.06] px-5 py-20 sm:px-6 sm:py-24 lg:px-8">
  <div class="pointer-events-none absolute inset-0 gradient-mesh"></div>
  <div class="presentation-shell">
    <div class="animate-on-scroll max-w-3xl">
      <div class="section-kicker">{kicker}</div>
      <h2 class="section-title mt-4">{process.title}</h2>
    </div>

    <div class="presentation-panel animate-on-scroll mt-10 grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground/65">
          {process.bridge.kicker}
        </div>
        <h3 class="mt-4 max-w-2xl text-2xl font-semibold tracking-tight text-foreground sm:text-[2rem]">
          {process.bridge.title}
        </h3>
      </div>

      <div>
        <ul class="space-y-3">
          {
            process.bridge.bullets.map((bullet) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-indigo-400"></span>
                <span class="text-sm leading-relaxed text-muted-foreground sm:text-base">{bullet}</span>
              </li>
            ))
          }
        </ul>

        <p class="mt-5 text-sm leading-relaxed text-muted-foreground">{process.bridge.note}</p>
      </div>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {
        process.steps.map((step, index) => (
          <article
            class="animate-on-scroll rounded-[1.75rem] border border-white/[0.08] bg-white/[0.03] px-6 py-6 shadow-xl shadow-black/15"
            style={`transition-delay: ${index * 90}ms`}
          >
            <div class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground/65">
              0{index + 1}
            </div>
            <h3 class="mt-4 text-xl font-semibold tracking-tight text-foreground">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">{step.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
