---
import { t, type Locale } from "@/i18n/utils";
import { countries } from "@/data/countries";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const countriesJson = JSON.stringify(countries);
const founder = i.team.members[0];
---

<section id="contact" class="relative border-t border-white/[0.06] py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        {i.contact.title}
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
        {i.contact.subtitle}
      </p>
    </div>

    <div class="mt-12">
      <div class="animate-on-scroll grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <!-- Info side -->
        <div class="space-y-6">
          <div class="rounded-[2rem] border border-white/[0.06] bg-white/[0.04] p-6 shadow-2xl shadow-black/20">
            <div class="flex items-start gap-4">
              <img
                src={founder.photo}
                alt={founder.name}
                class="h-16 w-16 flex-none rounded-2xl border border-white/[0.08] object-cover object-center"
                width="64"
                height="64"
                loading="lazy"
              />
              <div>
                <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/55">
                  {i.contact.calendly_label}
                </div>
                <div class="mt-2 text-lg font-semibold text-foreground">{founder.name}</div>
                <div class="text-sm text-primary">{i.founder.role}</div>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  {i.contact.founderCue}
                </p>
              </div>
            </div>

            <h3 class="mt-6 text-xl font-semibold text-foreground">{i.contact.call_title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
              {i.contact.call_summary}
            </p>

            <div class="mt-6 divide-y divide-white/[0.08] border-t border-white/[0.08]">
              {
                i.contact.call_points.map((point, idx) => (
                  <div class="py-4 first:pt-0 last:pb-0">
                    <div class="text-sm font-mono text-muted-foreground/45">
                      {String(idx + 1).padStart(2, "0")}
                    </div>
                    <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{point}</p>
                  </div>
                ))
              }
            </div>

            <a
              href="https://calendly.com/hello-awesomeworks/30min"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center rounded-full bg-indigo-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-400"
            >
              {i.contact.founderCta}
            </a>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
            <a
              href="mailto:hello@awesomeworks.ai"
              class="rounded-[1.5rem] border border-white/[0.06] bg-white/[0.03] p-5 transition-colors hover:border-indigo-500/20 hover:bg-white/[0.05]"
            >
              <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/55">
                {i.contact.email_label}
              </div>
              <div class="mt-3 text-base font-semibold text-foreground">hello@awesomeworks.ai</div>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                {i.contact.async_body}
              </p>
            </a>

            <div class="rounded-[1.5rem] border border-white/[0.06] bg-white/[0.03] p-5">
              <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/55">
                {i.contact.response_label}
              </div>
              <div class="mt-3 text-base font-semibold text-foreground">{i.contact.response_title}</div>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                {i.contact.response_body}
              </p>
            </div>
          </div>
        </div>

        <!-- Form side -->
        <div class="rounded-[2rem] border border-white/[0.06] bg-white/[0.03] p-6 sm:p-8">
          <h3 class="mb-5 text-lg font-semibold text-foreground">
            {i.contact.form_title}
          </h3>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-4"
          >
            <input type="hidden" name="access_key" value="96db43d4-48ed-482a-9186-a1527a1b7833" />
            <input type="hidden" name="redirect" value={`https://awesomeworks.ai/${locale}/`} />
            <input type="hidden" name="subject" value="New contact from awesomeworks.ai" />

            <div>
              <label for="name" class="mb-1.5 block text-sm font-medium text-foreground">
                {i.contact.form_name}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2.5 text-sm text-foreground placeholder-muted-foreground/50 outline-none transition-colors focus:border-indigo-500/40 focus:ring-1 focus:ring-indigo-500/20"
                placeholder={i.contact.form_name}
              />
            </div>

            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-foreground">
                {i.contact.form_email}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2.5 text-sm text-foreground placeholder-muted-foreground/50 outline-none transition-colors focus:border-indigo-500/40 focus:ring-1 focus:ring-indigo-500/20"
                placeholder={i.contact.form_email}
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone-input" class="mb-1.5 block text-sm font-medium text-foreground">
                {i.contact.form_phone}
              </label>
              <div class="relative flex">
                <button
                  type="button"
                  id="country-selector"
                  class="flex items-center gap-1.5 rounded-l-lg border border-r-0 border-white/[0.08] bg-white/[0.06] px-3 py-2.5 text-sm text-foreground transition-colors hover:bg-white/[0.08] focus:border-indigo-500/40 focus:ring-1 focus:ring-indigo-500/20 focus:outline-none shrink-0"
                  aria-expanded="false"
                  aria-haspopup="listbox"
                >
                  <span id="selected-flag" class="text-lg leading-none">🇵🇱</span>
                  <span id="selected-dial" class="text-xs text-muted-foreground">+48</span>
                  <svg class="h-3 w-3 text-muted-foreground" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
                </button>
                <input
                  type="tel"
                  id="phone-input"
                  autocomplete="tel-national"
                  inputmode="numeric"
                  class="w-full min-w-0 rounded-r-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2.5 text-sm text-foreground placeholder-muted-foreground/50 outline-none transition-colors focus:border-indigo-500/40 focus:ring-1 focus:ring-indigo-500/20"
                  placeholder={i.contact.form_phone_placeholder}
                />
                <input type="hidden" id="phone-hidden" name="phone" value="" />
                <div
                  id="country-dropdown"
                  class="absolute left-0 top-full z-50 mt-1 hidden w-72 overflow-hidden rounded-xl border border-white/[0.08] bg-background/95 shadow-xl backdrop-blur-xl"
                  role="listbox"
                >
                  <div class="border-b border-white/[0.06] p-2">
                    <input
                      type="text"
                      id="country-search"
                      class="w-full rounded-lg border border-white/[0.06] bg-white/[0.04] px-3 py-2 text-sm text-foreground placeholder-muted-foreground/50 outline-none focus:border-indigo-500/40"
                      placeholder={i.contact.form_phone_search}
                    />
                  </div>
                  <div id="country-list" class="max-h-48 overflow-y-auto overscroll-contain"></div>
                </div>
              </div>
            </div>

            <div>
              <label for="message" class="mb-1.5 block text-sm font-medium text-foreground">
                {i.contact.form_message}
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full rounded-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2.5 text-sm text-foreground placeholder-muted-foreground/50 outline-none transition-colors focus:border-indigo-500/40 focus:ring-1 focus:ring-indigo-500/20 resize-none"
                placeholder={i.contact.form_message}
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full rounded-full bg-indigo-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-400"
            >
              {i.contact.form_submit}
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ countriesJson }}>
  (function () {
    const countries = JSON.parse(countriesJson);
    const selectorBtn = document.getElementById("country-selector");
    const flagEl = document.getElementById("selected-flag");
    const dialEl = document.getElementById("selected-dial");
    const phoneInput = document.getElementById("phone-input");
    const hiddenInput = document.getElementById("phone-hidden");
    const dropdown = document.getElementById("country-dropdown");
    const searchInput = document.getElementById("country-search");
    const listEl = document.getElementById("country-list");

    let currentDial = "48";
    let isOpen = false;

    // --- Format phone: space every 3 digits, max 15 ---
    function formatPhone(digits) {
      const d = digits.slice(0, 15);
      let out = "";
      for (let i = 0; i < d.length; i++) {
        if (i > 0 && i % 3 === 0) out += " ";
        out += d[i];
      }
      return out;
    }

    // --- Sync hidden input ---
    function syncHidden() {
      const digits = phoneInput.value.replace(/\D/g, "");
      hiddenInput.value = digits ? "+" + currentDial + " " + formatPhone(digits) : "";
    }

    // --- Render country list ---
    function renderList(filter) {
      const q = (filter || "").toLowerCase();
      const filtered = q
        ? countries.filter(
            (c) =>
              c.name.toLowerCase().includes(q) ||
              c.dial.includes(q) ||
              c.code.toLowerCase().includes(q)
          )
        : countries;

      listEl.innerHTML = filtered
        .map(
          (c) =>
            '<button type="button" class="flex w-full items-center gap-3 px-3 py-2 text-sm text-foreground transition-colors hover:bg-white/[0.06]" data-dial="' +
            c.dial +
            '" data-flag="' +
            c.flag +
            '" data-code="' +
            c.code +
            '"><span class="text-lg leading-none">' +
            c.flag +
            '</span><span class="flex-1 text-left">' +
            c.name +
            '</span><span class="text-xs text-muted-foreground">+' +
            c.dial +
            "</span></button>"
        )
        .join("");
    }

    // --- Toggle dropdown ---
    function openDropdown() {
      dropdown.classList.remove("hidden");
      selectorBtn.setAttribute("aria-expanded", "true");
      isOpen = true;
      searchInput.value = "";
      renderList("");
      requestAnimationFrame(() => searchInput.focus());
    }

    function closeDropdown() {
      dropdown.classList.add("hidden");
      selectorBtn.setAttribute("aria-expanded", "false");
      isOpen = false;
    }

    // --- Select country ---
    function selectCountry(dial, flag) {
      currentDial = dial;
      flagEl.textContent = flag;
      dialEl.textContent = "+" + dial;
      closeDropdown();
      phoneInput.focus();
      syncHidden();
    }

    // --- Event: toggle selector ---
    selectorBtn.addEventListener("click", function (e) {
      e.preventDefault();
      isOpen ? closeDropdown() : openDropdown();
    });

    // --- Event: country list click ---
    listEl.addEventListener("click", function (e) {
      const btn = e.target.closest("[data-dial]");
      if (btn) selectCountry(btn.dataset.dial, btn.dataset.flag);
    });

    // --- Event: search ---
    searchInput.addEventListener("input", function () {
      renderList(searchInput.value);
    });

    // --- Event: close on outside click ---
    document.addEventListener("click", function (e) {
      if (isOpen && !dropdown.contains(e.target) && !selectorBtn.contains(e.target)) {
        closeDropdown();
      }
    });

    // --- Event: close on Escape ---
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && isOpen) closeDropdown();
    });

    // --- Event: phone input (format live) ---
    phoneInput.addEventListener("input", function () {
      const raw = phoneInput.value.replace(/\D/g, "").slice(0, 15);
      const formatted = formatPhone(raw);

      // Preserve cursor position
      const sel = phoneInput.selectionStart;
      const prevLen = phoneInput.value.length;
      phoneInput.value = formatted;
      const diff = phoneInput.value.length - prevLen;
      phoneInput.setSelectionRange(sel + diff, sel + diff);

      syncHidden();
    });

    // --- Event: paste handling ---
    phoneInput.addEventListener("paste", function (e) {
      e.preventDefault();
      let text = (e.clipboardData || window.clipboardData).getData("text");
      let digits = text.replace(/\D/g, "");

      // Try to detect country code from pasted number
      if (text.trim().startsWith("+") || digits.length > 12) {
        for (let i = 0; i < countries.length; i++) {
          const c = countries[i];
          const dialClean = c.dial.replace(/-/g, "");
          if (digits.startsWith(dialClean)) {
            selectCountry(c.dial, c.flag);
            digits = digits.slice(dialClean.length);
            break;
          }
        }
      }

      digits = digits.slice(0, 15);
      phoneInput.value = formatPhone(digits);
      syncHidden();
    });

    // --- Event: prevent non-numeric keys ---
    phoneInput.addEventListener("keydown", function (e) {
      // Allow: backspace, delete, tab, escape, enter, arrows, home, end
      if (
        [8, 9, 13, 27, 46].includes(e.keyCode) ||
        (e.keyCode >= 35 && e.keyCode <= 40) ||
        ((e.ctrlKey || e.metaKey) && [65, 67, 86, 88, 90].includes(e.keyCode))
      ) {
        return;
      }
      // Block non-digit
      if (e.key.length === 1 && !/\d/.test(e.key)) {
        e.preventDefault();
      }
    });

    // Init
    renderList("");
    syncHidden();
  })();
</script>
