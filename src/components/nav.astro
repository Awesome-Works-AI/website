---
import LanguagePicker from "./language-picker.astro";
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getPersonalHome(locale);
const currentPath = Astro.url.pathname;
const homeHref = `/${locale}/`;
const isHomePage = currentPath === "/" || new RegExp(`^/${locale}/?$`).test(currentPath);

const brand = home.nav.brand ?? "Rafał Łazicki";
const brandInitials = brand
  .split(/\s+/)
  .map((part) => part[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("");

const ctaLabel = home.nav.cta;
const ctaHref = home.hero.primaryHref;
const ctaIsExternal = /^(https?:|mailto:)/.test(ctaHref);
---

<header
  class="pointer-events-none fixed inset-x-0 top-3 z-50 flex items-center justify-between gap-3 px-3 sm:top-4 sm:px-6"
  aria-label="Primary"
>
  <a
    href={homeHref}
    class="pointer-events-auto inline-flex items-center gap-2 rounded-full border border-white/[0.10] bg-background/65 px-3 py-1.5 shadow-lg shadow-black/30 backdrop-blur-xl transition hover:border-white/20 hover:bg-background/85 sm:py-2"
  >
    <span class="grid h-6 w-6 place-items-center rounded-full bg-foreground text-[10px] font-black uppercase tracking-tight text-background">
      {brandInitials}
    </span>
    <span class="hidden text-sm font-semibold tracking-tight text-foreground sm:inline">{brand}</span>
  </a>

  <div class="pointer-events-auto inline-flex items-center gap-2 rounded-full border border-white/[0.10] bg-background/65 p-1 pl-3 shadow-lg shadow-black/30 backdrop-blur-xl">
    <LanguagePicker currentLocale={locale} />
    <a
      href={ctaHref}
      target={ctaIsExternal ? "_blank" : undefined}
      rel={ctaIsExternal ? "noopener noreferrer" : undefined}
      class="inline-flex h-9 items-center rounded-full bg-red-500 px-4 text-xs font-semibold uppercase tracking-[0.14em] text-white shadow-md shadow-red-500/30 transition hover:bg-red-400 sm:text-sm sm:tracking-[0.08em]"
    >
      {ctaLabel}
    </a>
  </div>
</header>
