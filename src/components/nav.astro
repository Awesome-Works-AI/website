---
import LanguagePicker from "./language-picker.astro";
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getPersonalHome(locale);
const currentPath = Astro.url.pathname;
const homeHref = `/${locale}/`;
const isStoryPage = new RegExp(`^/${locale}/story/?$`).test(currentPath);
const resolvedLinks = home.nav.links.map((link) => {
  const base = { id: link.id, label: link.label, active: false };

  if (link.id === "story") return { ...base, href: `/${locale}/story`, active: isStoryPage };
  if (link.id === "work") return { ...base, href: `${homeHref}#work` };
  if (link.id === "socials") return { ...base, href: `${homeHref}#socials` };

  return { ...base, href: `${homeHref}#contact` };
});
---

<nav
  aria-label="Section navigation"
  class="pointer-events-none fixed left-6 top-1/2 z-50 hidden -translate-y-1/2 lg:flex"
>
  <div class="pointer-events-auto flex flex-col items-start gap-6">
    <a
      href={`/${locale}/`}
      class="text-[10px] font-semibold uppercase tracking-[0.34em] text-muted-foreground/45 transition-colors hover:text-foreground"
    >
      {home.nav.brand}
    </a>

    <div class="flex flex-col gap-3">
      {
        resolvedLinks.map((link) => (
          <a
            href={link.href}
            aria-current={link.active ? "page" : undefined}
            class:list={[
              "group flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.26em] transition-colors",
              link.active ? "text-foreground" : "text-muted-foreground/62 hover:text-foreground",
            ]}
          >
            <span
              class:list={[
                "h-px transition-all duration-200",
                link.active ? "w-10 bg-foreground" : "w-6 bg-white/18 group-hover:w-8 group-hover:bg-white/40",
              ]}
            ></span>
            <span>{link.label}</span>
          </a>
        ))
      }
    </div>

    <div class="pt-3">
      <LanguagePicker currentLocale={locale} />
    </div>
  </div>
</nav>

<div class="fixed right-4 top-5 z-50 lg:hidden">
  <LanguagePicker currentLocale={locale} />
</div>
