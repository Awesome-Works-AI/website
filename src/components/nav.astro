---
import LanguagePicker from "./language-picker.astro";
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getPersonalHome(locale);
const currentPath = Astro.url.pathname;
const homeHref = `/${locale}/`;
const isStoryPage = new RegExp(`^/${locale}/story/?$`).test(currentPath);
const resolvedLinks = home.nav.links.map((link) => {
  const base = { id: link.id, label: link.label, active: false };

  if (link.id === "story") return { ...base, href: `/${locale}/story`, active: isStoryPage };
  if (link.id === "work") return { ...base, href: `${homeHref}#work` };
  if (link.id === "socials") return { ...base, href: `${homeHref}#socials` };

  return { ...base, href: `${homeHref}#contact` };
});
---

<nav
  id="navbar"
  class="fixed inset-x-0 top-0 z-50 border-b border-white/[0.06] bg-background/80 backdrop-blur-xl"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href={`/${locale}/`} class="flex min-w-0 items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-white/[0.08] bg-white/[0.05] text-sm font-semibold text-foreground">
        RŁ
      </div>
      <div class="min-w-0">
        <div class="truncate text-sm font-semibold text-foreground">{home.nav.brand}</div>
        <div class="truncate text-[11px] uppercase tracking-[0.22em] text-muted-foreground/70">
          {home.nav.brandSubline}
        </div>
      </div>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {
        resolvedLinks.map((link) => (
          <a
            href={link.href}
            aria-current={link.active ? "page" : undefined}
            class:list={[
              "text-sm transition-colors hover:text-foreground",
              link.active ? "text-foreground" : "text-muted-foreground",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="hidden items-center gap-3 md:flex">
      <LanguagePicker currentLocale={locale} />
      <a
        href="https://calendly.com/hello-awesomeworks/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full border border-white/[0.1] bg-white/[0.06] px-4 py-2 text-sm font-semibold text-foreground transition-colors hover:bg-white/[0.1]"
      >
        {home.nav.cta}
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center rounded-2xl border border-white/[0.08] bg-white/[0.05] md:hidden"
      aria-label="Toggle menu"
    >
      <svg
        id="hamburger-icon"
        class="h-5 w-5 text-foreground"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg
        id="close-icon"
        class="hidden h-5 w-5 text-foreground"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-white/[0.06] bg-background/95 backdrop-blur-xl md:hidden"
  >
    <div class="flex flex-col gap-1 px-4 py-4">
      {
        resolvedLinks.map((link) => (
          <a
            href={link.href}
            aria-current={link.active ? "page" : undefined}
            class:list={[
              "rounded-xl px-3 py-2.5 text-sm transition-colors hover:bg-white/[0.04] hover:text-foreground",
              link.active ? "bg-white/[0.04] text-foreground" : "text-muted-foreground",
            ]}
          >
            {link.label}
          </a>
        ))
      }

      <div class="mt-3 flex items-center gap-3 border-t border-white/[0.06] pt-4">
        <LanguagePicker currentLocale={locale} />
        <a
          href="https://calendly.com/hello-awesomeworks/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 rounded-full border border-white/[0.1] bg-white/[0.06] px-4 py-2.5 text-center text-sm font-semibold text-foreground"
        >
          {home.nav.cta}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburger = document.getElementById("hamburger-icon");
  const close = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    hamburger?.classList.toggle("hidden");
    close?.classList.toggle("hidden");
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      hamburger?.classList.remove("hidden");
      close?.classList.add("hidden");
    });
  });
</script>
