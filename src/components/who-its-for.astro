---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { fit } = getPersonalHome(locale);
const fitLabel = locale === "pl" ? "Działa najlepiej" : "Best fit";
const noFitLabel = locale === "pl" ? "Nie jest dla" : "Not a fit";
---

<section class="relative flex min-h-[100svh] items-center border-t border-white/[0.06] px-5 py-20 sm:px-6 sm:py-24 lg:px-8">
  <div class="presentation-shell">
    <div class="animate-on-scroll max-w-3xl">
      <div class="section-kicker">{locale === "pl" ? "Fit" : "Fit"}</div>
      <h2 class="section-title mt-4">{fit.title}</h2>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-2">
      <article class="animate-on-scroll rounded-[1.75rem] border border-emerald-400/20 bg-emerald-400/[0.05] px-6 py-6 shadow-xl shadow-black/10">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-200/75">
          {fitLabel}
        </div>
        <div class="mt-5 space-y-4">
          {
            fit.good.map((item) => (
              <div class="flex gap-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
                <span class="mt-1 h-2 w-2 flex-none rounded-full bg-emerald-300"></span>
                <span>{item}</span>
              </div>
            ))
          }
        </div>
      </article>

      <article class="animate-on-scroll rounded-[1.75rem] border border-white/[0.08] bg-white/[0.03] px-6 py-6 shadow-xl shadow-black/10" style="transition-delay: 80ms">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground/65">
          {noFitLabel}
        </div>
        <div class="mt-5 space-y-4">
          {
            fit.bad.map((item) => (
              <div class="flex gap-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
                <span class="mt-1 h-2 w-2 flex-none rounded-full bg-white/35"></span>
                <span>{item}</span>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </div>
</section>
