---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { focus } = getPersonalHome(locale);
---

<section class="presentation-slide border-t border-white/[0.06]">
  <div class="presentation-shell">
    <div class="presentation-panel animate-on-scroll">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.7fr)] lg:items-end">
        <div class="max-w-3xl">
          <div class="section-kicker">{focus.eyebrow}</div>
          <h2 class="section-title mt-4 max-w-3xl">{focus.title}</h2>
          <p class="section-copy mt-6 max-w-2xl">{focus.description}</p>
          <a
            href={focus.storyHref}
            class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          >
            <span>{focus.storyCta}</span>
          </a>
        </div>

        <div class="grid gap-3">
          {
            focus.points.map((point) => (
              <div class="rounded-[1.5rem] border border-white/[0.08] bg-background/60 px-5 py-4 text-sm leading-relaxed text-foreground/88 sm:text-base">
                {point}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
