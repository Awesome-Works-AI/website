---
import type { Locale } from "@/i18n/utils";

interface Props {
  currentLocale: Locale;
}

const { currentLocale } = Astro.props;
const otherLocale = currentLocale === "en" ? "pl" : "en";
const otherLabel = currentLocale === "en" ? "PL" : "EN";
const currentPath = Astro.url.pathname;
const localizedPath = /^\/(pl|en)(?=\/|$)/.test(currentPath) ? currentPath : `/${currentLocale}/`;
const alternatePath = localizedPath.replace(/^\/(pl|en)(?=\/|$)/, `/${otherLocale}`);
---

<a
  href={alternatePath}
  class="inline-flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.28em] text-muted-foreground/60 transition-colors hover:text-foreground"
>
  <span class="text-muted-foreground/35">Lang</span>
  <span>{otherLabel}</span>
</a>
