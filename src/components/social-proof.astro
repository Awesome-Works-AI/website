---
import { t, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section id="proof" class="relative border-t border-white/[0.06] py-16 sm:py-24">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-end">
      <div class="animate-on-scroll lg:col-span-5">
        <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/60">
          {i.social_proof.eyebrow}
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          {i.social_proof.title}
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
          {i.social_proof.subtitle}
        </p>
      </div>

      <div class="animate-on-scroll lg:col-span-7">
        <div class="grid gap-0 border-y border-white/[0.08] sm:grid-cols-3">
          {
            i.social_proof.stats.map((stat, idx) => (
              <div
                class:list={[
                  "py-4 sm:px-5",
                  idx !== 0 && "border-t border-white/[0.08] sm:border-t-0 sm:border-l",
                ]}
                style={`transition-delay: ${idx * 80}ms`}
              >
                <div class="text-base font-semibold text-foreground sm:text-lg">{stat.value}</div>
                <div class="mt-1 text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground/65">
                  {stat.label}
                </div>
                <div class="mt-2 text-sm leading-relaxed text-muted-foreground">{stat.detail}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-14 grid items-start gap-10 lg:grid-cols-12">
      <div class="animate-on-scroll lg:col-span-7">
        <div class="max-w-3xl border-l-[3px] border-l-indigo-500/60 pl-6 sm:pl-8">
          <div class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground/60">
            {i.social_proof.featured.label}
          </div>
          <h3 class="mt-4 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            {i.social_proof.featured.title}
          </h3>
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
            {i.social_proof.featured.description}
          </p>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="divide-y divide-white/[0.08] border-t border-white/[0.08]">
          {
            i.social_proof.items.map((item, idx) => (
              <div
                class="animate-on-scroll py-5 first:pt-0"
                style={`transition-delay: ${120 + idx * 90}ms`}
              >
                <div class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground/55">
                  {item.title}
                </div>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground sm:text-base">
                  {item.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
