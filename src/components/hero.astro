---
import { getPersonalHome } from "@/data/personal-home";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { hero } = getPersonalHome(locale);
const isPrimaryExternal = /^(https?:|mailto:)/.test(hero.primaryHref);
const isSecondaryExternal = /^(https?:|mailto:)/.test(hero.secondaryHref);
const hasSecondaryCta = Boolean(hero.secondaryCta && hero.secondaryHref);
---

<section id="top" class="relative flex min-h-[100svh] items-center overflow-hidden px-5 pb-16 pt-20 sm:px-6 sm:pt-24 lg:px-8">
  <div class="pointer-events-none absolute inset-0 gradient-mesh-strong"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-64 bg-[radial-gradient(circle_at_top,rgba(99,102,241,0.16),transparent_55%)]"></div>

  <div class="presentation-shell pt-4">
    <div class="presentation-panel animate-on-scroll max-w-5xl">
      <div class="max-w-4xl">
        <div class="section-kicker">{hero.eyebrow}</div>
        <h1 class="mt-4 max-w-4xl text-[2.125rem] font-semibold tracking-tight text-foreground sm:text-6xl lg:text-7xl">
          {hero.title}
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-muted-foreground sm:text-xl">
          {hero.subtitle}
        </p>

        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap">
          <a
            href={hero.primaryHref}
            target={isPrimaryExternal ? "_blank" : undefined}
            rel={isPrimaryExternal ? "noopener noreferrer" : undefined}
            class="inline-flex items-center rounded-full bg-foreground px-6 py-3 text-sm font-semibold text-background transition-opacity hover:opacity-90"
          >
            {hero.primaryCta}
          </a>
          {
            hasSecondaryCta && (
              <a
                href={hero.secondaryHref}
                target={isSecondaryExternal ? "_blank" : undefined}
                rel={isSecondaryExternal ? "noopener noreferrer" : undefined}
                class="inline-flex items-center rounded-full border border-white/[0.12] bg-white/[0.04] px-6 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-white/[0.08]"
              >
                {hero.secondaryCta}
              </a>
            )
          }
          {
            hero.storyCta && hero.storyHref && (
              <a
                href={hero.storyHref}
                class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
              >
                <span>{hero.storyCta}</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
