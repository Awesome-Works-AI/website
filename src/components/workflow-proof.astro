---
import { t, type Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section id="workflow" class="relative overflow-hidden bg-gray-950 py-24 sm:py-32">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(99,102,241,0.14),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.08),transparent_30%)]"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-y-16">
      <div class="animate-on-scroll lg:col-span-4">
        <div class="text-xs font-medium uppercase tracking-[0.2em] text-white/45">
          {i.workflow.eyebrow}
        </div>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {i.workflow.title}
        </h2>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-white/65 sm:text-lg">
          {i.workflow.subtitle}
        </p>
      </div>

      <div class="lg:col-span-8">
        <div class="animate-on-scroll flex flex-col gap-3 rounded-xl border border-white/10 bg-white/[0.03] px-5 py-4 text-sm text-white/70 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-white/45">
            {i.workflow.rhythm.label}
          </span>
          {
            i.workflow.rhythm.items.map((item, idx) => (
              <div class="flex items-center gap-4">
                {idx !== 0 && <span class="hidden h-4 w-px bg-white/10 sm:block"></span>}
                <span>{item}</span>
              </div>
            ))
          }
        </div>

        <div class="mt-8 border-l border-white/10 pl-6 sm:pl-8">
          <div class="space-y-8">
            {
              i.workflow.steps.map((step, idx) => (
                <div
                  class:list={[
                    "animate-on-scroll relative",
                    idx === 3 ? "sm:ml-8" : "max-w-2xl",
                  ]}
                  style={`transition-delay: ${idx * 100}ms`}
                >
                  <div class="absolute -left-[1.95rem] top-1 h-3 w-3 rounded-full border border-emerald-300/40 bg-gray-950 sm:-left-[2.45rem]"></div>
                  <div class="text-sm font-mono text-emerald-300/70">0{step.number}</div>
                  <h3 class="mt-2 text-xl font-semibold text-white sm:text-2xl">{step.title}</h3>
                  <p class="mt-3 leading-relaxed text-white/65">{step.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="animate-on-scroll lg:col-span-7 lg:col-start-5">
        <div class="rounded-[1.5rem] bg-white/95 p-7 text-gray-900 sm:p-8">
          <div class="text-xs font-medium uppercase tracking-[0.2em] text-gray-500">
            {i.workflow.first_call.label}
          </div>
          <h3 class="mt-4 max-w-xl text-2xl font-bold tracking-tight">{i.workflow.first_call.title}</h3>
          <div class="mt-6 divide-y divide-gray-200/80 border-t border-gray-200/80">
            {
              i.workflow.first_call.items.map((item, idx) => (
                <div class="py-4 first:pt-0 last:pb-0" style={`transition-delay: ${80 + idx * 80}ms`}>
                  <div class="text-sm font-medium text-gray-900">{item.title}</div>
                  <div class="mt-1 text-sm leading-relaxed text-gray-600">{item.description}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="animate-on-scroll lg:col-span-4 lg:col-start-9">
        <div class="max-w-sm text-sm leading-relaxed text-white/55">
          <div class="text-xs uppercase tracking-[0.2em] text-white/35">{i.workflow.rhythm.title}</div>
          <p class="mt-3">
            {i.workflow.rhythm.items[0]}. {i.workflow.rhythm.items[1]}. {i.workflow.rhythm.items[2]}.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
