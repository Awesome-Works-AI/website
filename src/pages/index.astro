---
const redirectPath = "/en/";
const siteBase = Astro.site?.href ?? "https://awesomeworks.ai";
const redirectUrl = new URL(redirectPath, siteBase);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${redirectPath}`} />
    <title>Redirecting...</title>
    <link rel="canonical" href={redirectUrl.href} />
  </head>
  <body>
    <p>Redirecting to <a href={redirectPath}>the English homepage</a>.</p>
    <script>
      window.location.replace("/en/");
    </script>
  </body>
</html>
