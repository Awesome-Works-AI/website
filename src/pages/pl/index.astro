---
import Authority from "@/components/authority.astro";
import Bottlenecks from "@/components/bottlenecks.astro";
import Closing from "@/components/closing.astro";
import Footer from "@/components/footer.astro";
import Hero from "@/components/hero.astro";
import HowItWorks from "@/components/how-it-works.astro";
import Nav from "@/components/nav.astro";
import Products from "@/components/projects-carousel.astro";
import Questions from "@/components/questions.astro";
import Socials from "@/components/socials.astro";
import { getPersonalHome } from "@/data/personal-home";
import Base from "@/layouts/base.astro";

const locale = "pl";
const home = getPersonalHome(locale);
---

<Base
  title={home.meta.title}
  description={home.meta.description}
  socialDescription={home.meta.socialDescription}
  locale={locale}
  includeFaqSchema={true}
>
  <Nav locale={locale} />
  <main>
    <Hero locale={locale} />
    <Bottlenecks locale={locale} />
    <Products locale={locale} />
    <Authority locale={locale} />
    <HowItWorks locale={locale} />
    <Questions locale={locale} />
    <Socials locale={locale} />
    <Closing locale={locale} />
    <Footer locale={locale} />
  </main>
</Base>
