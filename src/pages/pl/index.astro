---
import Closing from "@/components/closing.astro";
import Founder from "@/components/founder.astro";
import Focus from "@/components/focus.astro";
import Hero from "@/components/hero.astro";
import Nav from "@/components/nav.astro";
import Pivot from "@/components/pivot.astro";
import Products from "@/components/products.astro";
import Socials from "@/components/socials.astro";
import { getPersonalHome } from "@/data/personal-home";
import Base from "@/layouts/base.astro";

const locale = "pl";
const home = getPersonalHome(locale);
---

<Base
  title={home.meta.title}
  description={home.meta.description}
  socialDescription={home.meta.socialDescription}
  locale={locale}
>
  <Nav locale={locale} />
  <main>
    <Hero locale={locale} />
    <Founder locale={locale} />
    <Pivot locale={locale} />
    <Focus locale={locale} />
    <Products locale={locale} />
    <Socials locale={locale} />
    <Closing locale={locale} />
  </main>
</Base>
