---
import Base from "@/layouts/base.astro";
import ComparisonNav from "@/components/comparison/nav.astro";
import ComparisonHero from "@/components/comparison/hero.astro";
import FeatureTable from "@/components/comparison/feature-table.astro";
import Section from "@/components/comparison/section.astro";
import ComparisonCta from "@/components/comparison/cta.astro";
import Disclaimer from "@/components/comparison/disclaimer.astro";
import Footer from "@/components/footer.astro";

const locale = "en";
---

<Base
  title="CallWise vs Read.ai — AI Sales Scoring, Not Transcription"
  description="Read.ai transcribes meetings. CallWise scores sales calls across 28 AI metrics with built-in VoIP, CRM, and coaching. From ~$26/user/mo."
  locale={locale}
>
  <ComparisonNav locale={locale} competitorName="Read.ai" />

  <main>
    <ComparisonHero
      title="Beyond Meeting Transcription:"
      titleGradient="AI That Actually Coaches Your Sales Team"
      subtitle="Read.ai counts filler words. CallWise scores objection handling."
      ctaText="Start Free Trial"
      ctaUrl="https://app.callwise.ai"
      microCopy="14-day free trial · Built-in VoIP · Built-in CRM"
    />

    <Section title="Meeting Analysis ≠ Sales Analysis">
      <p>
        Read.ai is a great meeting assistant. It transcribes your Zoom calls, tracks who talked the most, counts your filler words, and gives you a tidy summary.
      </p>
      <p>
        But a sales call isn't just a meeting. It's a <strong>revenue event</strong>. The question isn't "who talked the most?" — it's "did the rep uncover the prospect's real pain point?", "was the pricing objection handled?", "did they establish next steps with a concrete date?"
      </p>
      <p>
        Read.ai analyzes <strong>meeting quality</strong>: pace, engagement, talk ratio. CallWise analyzes <strong>sales quality</strong>: discovery, objection handling, closing technique, empathy. Same call, completely different lens.
      </p>
    </Section>

    <FeatureTable
      title="Feature Comparison"
      competitorLabel="Read.ai"
      rows={[
        { feature: "AI call scoring (sales-specific)", callwise: "✅ 28 metrics", competitor: "❌ Engagement only" },
        { feature: "Explainable AI (SHAP)", callwise: "✅ Why this score", competitor: "❌" },
        { feature: "Per-45s micro-coaching", callwise: "✅", competitor: "❌" },
        { feature: "Built-in VoIP", callwise: "✅ Native", competitor: "❌ Meetings only" },
        { feature: "CRM with deal pipeline", callwise: "✅", competitor: "❌" },
        { feature: "Auto CRM data entry", callwise: "✅", competitor: "❌" },
        { feature: "SMS meeting reminders", callwise: "✅ 98% open rate", competitor: "❌" },
        { feature: "Discovery form extraction", callwise: "✅", competitor: "❌" },
        { feature: "AI Agent (21 tools)", callwise: "✅", competitor: "Digital Twin Ada" },
        { feature: "Meeting transcription", callwise: "✅", competitor: "✅" },
        { feature: "Multi-platform (Zoom/Teams/Meet)", callwise: "Meet + VoIP", competitor: "✅ All platforms" },
        { feature: "Cross-platform search", callwise: "❌", competitor: "✅" },
        { feature: "SOC 2 / HIPAA", callwise: "❌", competitor: "✅" },
        { feature: "Pricing (entry/user/mo)", callwise: "~$26", competitor: "$15" },
      ]}
    />

    <Section title="What a CallWise Analysis Looks Like" variant="highlight">
      <p>
        Every call goes through CallWise's AI pipeline: <strong>28 sales-specific metrics</strong> scored and explained — discovery quality, objection handling, empathy, closing technique, rapport building, and more. Each metric gets a <strong>SHAP explanation</strong> showing WHY that score was given.
      </p>
      <p>
        The <strong>per-45-second timeline</strong> shows exact moments: minute 3 — excellent rapport building. Minute 14 — missed budget objection. Minute 22 — strong close with concrete next steps.
      </p>
      <p>
        When the call ends, CallWise <strong>auto-fills your CRM</strong> with the prospect's timeline, budget range, and decision-maker. It drafts a follow-up email. It schedules SMS reminders with the right cadence.
      </p>
      <p>
        <strong>Read.ai tells you how your meeting went. CallWise tells you how to win the deal.</strong>
      </p>
    </Section>

    <Section title="Sales Tools Read.ai Doesn't Have">
      <p>
        CallWise includes tools that Read.ai doesn't — because they're built for <strong>sales, not meetings</strong>:
      </p>
      <ul>
        <li><strong>Built-in VoIP dialer</strong> — make and receive calls directly, no separate phone system needed.</li>
        <li><strong>CRM with deal pipeline</strong> — track leads, stages, and revenue without Salesforce or HubSpot.</li>
        <li><strong>SMS meeting reminders</strong> — automated multi-cadence reminders with 98% open rates (industry average).</li>
        <li><strong>AI Agent with 21 tools</strong> — drafts follow-ups, fills CRM fields, summarizes calls, suggests next actions.</li>
        <li><strong>Discovery form extraction</strong> — automatically pulls structured data from sales conversations.</li>
        <li><strong>HubSpot two-way sync</strong> — if you already use HubSpot, CallWise enriches your data.</li>
      </ul>
    </Section>

    <Section title="Who Should Use Which">
      <p><strong>Choose Read.ai if:</strong></p>
      <ul>
        <li>Your problem is <strong>meeting productivity</strong> across all departments (product, HR, marketing, engineering)</li>
        <li>You need <strong>multi-platform support</strong> (Zoom + Teams + Meet)</li>
        <li>You need <strong>SOC 2 + HIPAA compliance</strong> today</li>
        <li>You want a <strong>lightweight meeting assistant</strong> at $15/user/mo</li>
      </ul>
      <p><strong>Choose CallWise if:</strong></p>
      <ul>
        <li>Your problem is <strong>sales performance</strong> and call coaching</li>
        <li>You want AI that scores <strong>sales-specific skills</strong> (not just engagement)</li>
        <li>You need a <strong>phone system + CRM + coaching</strong> in one tool</li>
        <li>You want <strong>explainable AI</strong> that shows reps exactly what to improve</li>
      </ul>
    </Section>

    <Section title="What Read.ai Does Better" variant="honesty">
      <p>
        Read.ai works with <strong>every major video platform</strong> — Zoom, Teams, and Meet. CallWise currently supports Google Meet and its built-in VoIP. Read.ai has <strong>SOC 2 Type 2 and HIPAA compliance</strong>. Read.ai's <strong>cross-platform search</strong> across meetings, emails, and chats is a genuine differentiator. And at <strong>$15/user/mo</strong>, Read.ai has a lower entry price point.
      </p>
      <p>
        If you need a general-purpose meeting intelligence tool for your entire organization, Read.ai is excellent at what it does.
      </p>
    </Section>

    <ComparisonCta
      title="Ready to Coach Your Sales Team?"
      subtitle="Stop counting filler words. Start scoring objection handling, discovery quality, and closing technique."
      ctaText="Start 14-Day Free Trial"
      ctaUrl="https://app.callwise.ai"
      features={["Built-in VoIP", "Built-in CRM", "No credit card", "28 AI metrics"]}
    />

    <Disclaimer competitors={["Read.ai"]} locale={locale} />
  </main>

  <Footer locale={locale} />
</Base>
