---
import Base from "@/layouts/base.astro";
import ComparisonNav from "@/components/comparison/nav.astro";
import ComparisonHero from "@/components/comparison/hero.astro";
import FeatureTable from "@/components/comparison/feature-table.astro";
import Section from "@/components/comparison/section.astro";
import ComparisonCta from "@/components/comparison/cta.astro";
import Disclaimer from "@/components/comparison/disclaimer.astro";
import Footer from "@/components/footer.astro";

const locale = "en";

const featureRows = [
  { feature: "AI call scoring", callwise: "✅ 28 metrics", competitor: "❌ Basic recording" },
  { feature: "Explainable AI (SHAP)", callwise: "✅ Why this score", competitor: "❌ Not available" },
  { feature: "Per-45s micro-coaching", callwise: "✅", competitor: "❌" },
  { feature: "Built-in VoIP", callwise: "✅ Native", competitor: "❌ Requires Vonage" },
  { feature: "CRM with deal pipeline", callwise: "✅", competitor: "✅ Market leader" },
  { feature: "Auto CRM data entry from calls", callwise: "✅", competitor: "❌ Manual" },
  { feature: "SMS meeting reminders", callwise: "✅ Auto multi-cadence", competitor: "❌ Email only" },
  { feature: "Discovery form extraction", callwise: "✅", competitor: "❌" },
  { feature: "AI Agent (21 tools)", callwise: "✅", competitor: "Breeze (limited)" },
  { feature: "Revenue forecasting", callwise: "❌", competitor: "✅" },
  { feature: "Integration ecosystem", callwise: "~5 integrations", competitor: "1,500+" },
  { feature: "Pricing (10 users/mo)", callwise: "~$520", competitor: "~$1,000" },
];
---

<Base
  title="CallWise vs HubSpot — Smarter Call AI, Half the Cost"
  description="CallWise scores every sales call across 28 AI metrics with built-in VoIP and CRM. HubSpot alternative at ~$52/user vs $100/seat. 14-day free trial."
  locale={locale}
>
  <ComparisonNav locale={locale} competitorName="HubSpot" />

  <main>
    <ComparisonHero
      title="The HubSpot Alternative"
      titleGradient="That Actually Coaches Your Sales Reps"
      subtitle="HubSpot logs your calls. CallWise scores them."
      ctaText="Start Free Trial"
      ctaUrl="https://app.callwise.ai"
      microCopy="14-day free trial · No credit card · No migration needed"
    />

    <Section title="The Problem with HubSpot's Call Intelligence" id="problem">
      <p>
        HubSpot is the world's most popular CRM — and for pipeline management, email sequences,
        and marketing automation, it's excellent. But when your reps hang up a call, HubSpot
        logs <strong>"Call — 18 minutes"</strong> and moves on.
      </p>
      <p>
        It records and transcribes, but doesn't score, doesn't explain, doesn't coach at the
        moment level. HubSpot's conversation intelligence is a feature buried in the
        <strong>$100/seat Professional tier</strong> — not a dedicated product.
      </p>
    </Section>

    <FeatureTable
      title="Feature Comparison"
      competitorLabel="HubSpot"
      rows={featureRows}
    />

    <Section title="How CallWise Call Scoring Works" id="how-it-works" variant="highlight">
      <p>
        Every call goes through a 4-stage pipeline: <strong>Recording → Transcription →
        28-metric AI analysis with SHAP explanations → Per-45-second coaching windows</strong>.
      </p>
      <p>
        When the call ends, CallWise auto-fills your CRM with the prospect's timeline, budget,
        and decision-maker — extracted directly from the conversation. Then it drafts a follow-up
        email with the exact context from the call.
      </p>
    </Section>

    <Section title="But I Already Use HubSpot" id="integration">
      <p>
        You don't have to leave HubSpot. CallWise syncs two-way with HubSpot so your data stays
        unified. Your pipeline, contacts, and deal stages remain in HubSpot — CallWise adds the
        intelligence layer that tells you <strong>WHY deals die on calls</strong>.
      </p>
      <p>
        Think of it as the call coaching engine HubSpot doesn't have.
      </p>
    </Section>

    <Section title="Pricing Comparison" id="pricing">
      <p>
        Transparent pricing: <strong>CallWise Professional at ~$52/user/mo</strong> vs
        <strong>HubSpot Sales Hub Professional at $100/seat/mo</strong>.
      </p>
      <p>
        For a 5-person team, that's <strong>$260/mo vs $500/mo</strong>. For 10 people,
        <strong>$520/mo vs $1,000/mo</strong>. And with CallWise, VoIP is included — no separate
        Vonage subscription needed.
      </p>
    </Section>

    <Section title="What HubSpot Does Better (And That's Fine)" id="honesty" variant="honesty">
      <p>
        HubSpot has <strong>1,500+ integrations</strong>, world-class marketing automation, CPQ,
        revenue forecasting, and a massive ecosystem. It's the dominant CRM for a reason.
      </p>
      <p>
        CallWise doesn't replace HubSpot — it fills the call intelligence gap HubSpot doesn't
        address. If your team needs deep marketing automation, HubSpot is the right choice. If
        your team needs to know <strong>why deals die on calls</strong>, add CallWise.
      </p>
    </Section>

    <ComparisonCta
      title="Start Scoring Your Sales Calls Today"
      subtitle="See what HubSpot can't show you — why your reps win and lose deals on the phone."
      ctaText="Start 14-Day Free Trial"
      ctaUrl="https://app.callwise.ai"
      features={["No credit card", "No migration", "HubSpot sync included"]}
    />
  </main>

  <Disclaimer competitors={["HubSpot"]} locale={locale} />
  <Footer locale={locale} />
</Base>
